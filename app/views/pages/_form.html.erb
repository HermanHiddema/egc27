<%= form_with model: page do |form| %>
  <% if page.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-6">
      <h2 class="text-red-800 font-semibold mb-2">There were errors with your submission:</h2>
      <ul class="text-red-700 list-disc list-inside">
        <% page.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="space-y-6">
    <div>
      <%= form.label :title, "Title *", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.text_field :title, class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-brand-blue-600 focus:border-brand-blue-600" %>
    </div>

    <div>
      <%= form.label :slug, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.text_field :slug, placeholder: "leave blank to generate from title", class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-brand-blue-600 focus:border-brand-blue-600" %>
    </div>

    <div>
      <%= form.label :content, "Content *", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <% if tinymce_editor? %>
        <% content_for :tinymce_script, "1" %>
        <%= form.text_area :content_html, data: { controller: "tinymce" }, class: "w-full rounded-lg border border-gray-300 bg-white" %>
      <% else %>
        <%= form.rich_textarea :content, class: "w-full rounded-lg border border-gray-300 bg-white" %>
      <% end %>
      <%= hidden_field_tag :editor, current_editor %>
    </div>

    <div>
      <%= form.label :main_image, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.file_field :main_image, accept: "image/png,image/jpeg,image/webp", class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-brand-blue-600 focus:border-brand-blue-600" %>
      <% if page.main_image.attached? && page.main_image.variable? %>
        <div class="mt-3 relative inline-block" data-controller="remove-image">
          <%= image_tag main_image_representation(page.main_image, resize_to_limit: [ 96, 96 ]), alt: "#{page.title} main image", class: "h-24 w-auto rounded-lg border border-gray-200 transition-opacity", data: { "remove-image-target": "image" } %>
          <button type="button" class="absolute top-2 right-2 p-1 bg-brand-red-600 text-white rounded-full hover:bg-brand-red-700 transition shadow-lg" data-action="click->remove-image#toggle" title="Remove image">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd"/>
            </svg>
          </button>
          <%= form.hidden_field :remove_main_image, value: "0", data: { "remove-image-target": "removeField" } %>
        </div>
      <% end %>
    </div>

    <div class="flex gap-4">
      <%= form.submit class: "btn-primary" %>
      <%= link_to "Cancel", pages_path, class: "text-brand-blue-600 hover:text-brand-red-600 transition px-4 py-2" %>
    </div>
  </div>
<% end %>