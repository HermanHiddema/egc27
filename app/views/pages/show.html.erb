<div class="container-wide py-12">
  <div class="mb-6">
    <%= link_to "← Back to Pages", pages_path, class: "text-brand-blue-600 hover:text-brand-red-600 transition" %>
  </div>

  <article class="bg-white border border-gray-200 rounded-lg p-8 shadow-sm">
    <header class="mb-6 border-b border-gray-200 pb-4 flex items-start justify-between gap-4">
      <div>
        <h1 class="text-4xl font-bold mb-2"><%= @page.title %></h1>
      </div>

      <% if current_user&.can_edit? %>
        <div class="flex gap-4 shrink-0">
          <%= link_to "Edit", edit_page_path(@page), class: "text-brand-blue-600 hover:text-brand-red-600 transition" %>
          <% if current_user&.can_delete? %>
            <%= button_to "Delete", page_path(@page), method: :delete, data: { turbo_confirm: "Are you sure you want to delete this page?" }, class: "text-brand-red-600 hover:text-brand-red-700 transition" %>
          <% end %>
        </div>
      <% end %>
    </header>

    <% if @page.main_image.attached? && @page.main_image.image? %>
      <div class="mb-8">
        <%= image_tag main_image_representation(@page.main_image, resize_to_limit: [ 1200, 512 ]), alt: "#{@page.title} main image", class: "w-full h-auto max-h-[32rem] object-cover rounded-lg border border-gray-200" %>
      </div>
    <% end %>

    <div class="rich-content trix-content max-w-none">
      <%= @page.content %>
    </div>
  </article>
</div>
