<% if user_signed_in? %>
  <%= render "shared/form_errors", model: event_registration %>
<% end %>

<% if !user_signed_in? %>
  <p class="text-gray-700">
    <%= link_to "Sign in", new_user_session_path, class: "text-brand-blue-600 hover:text-brand-red-600" %>
    to register one of your participants for this event.
  </p>
  <p class="text-sm text-gray-500 mt-2">
    Need to add a participant first?
    <%= link_to "Register as a participant", new_participant_path, class: "text-brand-blue-600 hover:text-brand-red-600" %>.
  </p>
<% elsif current_user.participants.none? %>
  <p class="text-gray-700">
    Your account does not have a participant yet.
    <%= link_to "Register as a participant", new_participant_path, class: "text-brand-blue-600 hover:text-brand-red-600" %>
    before registering for this event.
  </p>
<% elsif registrable_participants.any? %>
  <%= form_with model: event_registration, url: event_event_registrations_path(event), method: :post do |form| %>
    <div class="flex gap-4 items-end">
      <div class="flex-1">
        <% if registrable_participants.many? %>
          <%= form.label :participant_id, "Participant *", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= form.select :participant_id,
              options_for_select(
                registrable_participants.map { |participant| [[participant.first_name, participant.last_name].join(" "), participant.id] },
                event_registration.participant_id
              ),
              { prompt: "Choose a participant" },
              class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-brand-blue-600 focus:border-brand-blue-600" %>
        <% else %>
          <% participant = registrable_participants.first %>
          <%= form.hidden_field :participant_id, value: participant.id %>
          <div>
            <p class="block text-sm font-medium text-gray-700 mb-2">Participant</p>
            <p class="w-full border border-gray-200 rounded-lg px-4 py-2 bg-gray-50 text-gray-900"><%= [participant.first_name, participant.last_name].join(" ") %></p>
          </div>
        <% end %>
        <%= field_error form, :participant_id %>
      </div>
      <div>
        <%= form.submit "Register", class: "btn-primary" %>
      </div>
    </div>
  <% end %>
<% else %>
  <p class="text-gray-700">All of your participants are already registered for this event.</p>
<% end %>
