<%= form_with url: event_event_registrations_path(event), method: :post do |form| %>
  <% if event_registration.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-6">
      <h2 class="text-red-800 font-semibold mb-2">There were errors with your submission:</h2>
      <ul class="text-red-700 list-disc list-inside">
        <% event_registration.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="flex gap-4 items-end">
    <div class="flex-1">
      <%= form.label :email, "Your registration email address", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.email_field :email, placeholder: "Enter your registration email", class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-brand-blue-600 focus:border-brand-blue-600" %>
    </div>
    <div>
      <%= form.submit "Register", class: "btn-primary" %>
    </div>
  </div>
  <p class="text-sm text-gray-500 mt-2">
    Use the email address you registered with as a participant.
    Not registered yet? <%= link_to "Register as a participant", new_participant_path, class: "text-brand-blue-600 hover:text-brand-red-600" %>.
  </p>
<% end %>
