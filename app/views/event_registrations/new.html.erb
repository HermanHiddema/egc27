<div class="container-wide py-12">
  <div class="mb-6">
    <%= link_to "← Back to Event", event_path(@event), class: "text-brand-blue-600 hover:text-brand-red-600 transition" %>
  </div>

  <div class="bg-white border border-gray-200 rounded-lg p-8 shadow-sm">
    <h1 class="text-3xl font-bold mb-2">Register for Event</h1>
    <p class="text-gray-600 mb-8"><%= @event.title %></p>
    <%= render "form", event: @event, event_registration: @event_registration, registrable_participants: @registrable_participants %>
  </div>
</div>
