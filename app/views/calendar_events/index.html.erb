<div class="container-wide py-12">
  <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-8">
    <h1 class="text-4xl font-bold">Calendar</h1>
    <div class="flex items-center gap-3">
      <%= link_to "← Previous", calendar_path(month: (@month << 1).strftime("%Y-%m")), class: "text-brand-blue-600 hover:text-brand-red-600 transition" %>
      <%= link_to "Today", calendar_path(month: Date.current.strftime("%Y-%m")), class: "text-brand-blue-600 hover:text-brand-red-600 transition" %>
      <%= link_to "Next →", calendar_path(month: (@month >> 1).strftime("%Y-%m")), class: "text-brand-blue-600 hover:text-brand-red-600 transition" %>
      <% if user_signed_in? %>
        <%= link_to "New Event", new_calendar_event_path, class: "btn-primary" %>
      <% end %>
    </div>
  </div>

  <%= render "view_tabs" %>

  <div class="bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-200 bg-gray-50">
      <h2 class="text-2xl font-semibold"><%= @month.strftime("%B %Y") %></h2>
    </div>

    <div class="grid grid-cols-7 border-b border-gray-200 bg-gray-50 text-sm font-semibold text-gray-700">
      <% ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"].each do |day_name| %>
        <div class="px-3 py-2 border-r border-gray-200 last:border-r-0"><%= day_name %></div>
      <% end %>
    </div>

    <% @calendar_days.each_slice(7) do |week| %>
      <div class="grid grid-cols-7 border-b border-gray-200 last:border-b-0">
        <% week.each do |day| %>
          <% day_events = @calendar_events_by_day[day] || [] %>
          <% outside_month = day.month != @month.month %>
          <div class="min-h-36 p-2 border-r border-gray-200 last:border-r-0 <%= outside_month ? 'bg-gray-50 text-gray-400' : 'bg-white' %>">
            <div class="flex items-center justify-between mb-2">
              <%= link_to day.day, day_calendar_events_path(date: day), class: "text-sm font-semibold #{day == Date.current ? 'text-brand-red-600' : 'text-brand-blue-900 hover:text-brand-red-600'} transition" %>
            </div>

            <div class="space-y-1">
              <% day_events.each do |calendar_event| %>
                <%= link_to calendar_event_path(calendar_event), class: "block text-xs rounded px-2 py-1 bg-brand-blue-50 hover:bg-brand-blue-100 text-brand-blue-800 transition" do %>
                  <span class="font-semibold"><%= eu_time(calendar_event.starts_at) %></span>
                  <span><%= calendar_event.title %></span>
                <% end %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
