<div class="container-wide py-12">
  <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-6">
    <h1 class="text-4xl font-bold">Calendar — Day</h1>
    <div class="flex items-center gap-3">
      <%= link_to "← Previous", day_calendar_events_path(date: (@date - 1.day)), class: "text-brand-blue-600 hover:text-brand-red-600 transition" %>
      <%= link_to "Today", day_calendar_events_path(date: Date.current), class: "text-brand-blue-600 hover:text-brand-red-600 transition" %>
      <%= link_to "Next →", day_calendar_events_path(date: (@date + 1.day)), class: "text-brand-blue-600 hover:text-brand-red-600 transition" %>
      <% if user_signed_in? %>
        <%= link_to "New Event", new_calendar_event_path, class: "btn-primary" %>
      <% end %>
    </div>
  </div>

  <%= render "view_tabs" %>

  <div class="bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-200 bg-gray-50">
      <h2 class="text-2xl font-semibold"><%= eu_date(@date, weekday: :long) %></h2>
    </div>

    <div class="p-6 space-y-3">
      <% if @calendar_events.any? %>
        <% @calendar_events.each do |calendar_event| %>
          <%= link_to calendar_event_path(calendar_event), class: "block rounded-lg border border-gray-200 p-4 hover:bg-brand-blue-50 transition" do %>
            <div class="flex items-center justify-between gap-4">
              <div>
                <h3 class="text-lg font-semibold text-brand-blue-900"><%= calendar_event.title %></h3>
                <p class="text-sm text-gray-600">
                  <%= eu_time(calendar_event.starts_at) %> - <%= eu_time(calendar_event.ends_at) %>
                  <% if calendar_event.location.present? %>
                    • <%= calendar_event.location %>
                  <% end %>
                </p>
              </div>
              <span class="text-sm text-gray-500"><%= calendar_event.user.display_name %></span>
            </div>
          <% end %>
        <% end %>
      <% else %>
        <p class="text-gray-500">No events for this day.</p>
      <% end %>
    </div>
  </div>
</div>
