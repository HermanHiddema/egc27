<div class="container-wide py-12">
  <h1 class="text-4xl font-bold mb-8">Edit Event</h1>

  <div class="bg-white border border-gray-200 rounded-lg p-8 shadow-sm">
    <%= render "form", calendar_event: @calendar_event %>

    <% if current_user&.can_delete? %>
      <div class="mt-6 pt-6 border-t border-gray-200">
        <%= button_to "Delete Event",
            calendar_event_path(@calendar_event),
            method: :delete,
            data: { turbo_confirm: "Are you sure you want to delete this event?" },
            class: "text-brand-red-600 hover:text-brand-red-700 transition" %>
      </div>
    <% end %>
  </div>
</div>
