<%
  anchor_date =
    if defined?(@date) && @date.present?
      @date.to_date
    elsif defined?(@period_start) && @period_start.present?
      @period_start.to_date
    elsif defined?(@month) && @month.present?
      @month.beginning_of_month.to_date
    else
      Date.current
    end

  month_target = (defined?(@month) && @month.present?) ? @month.to_date : anchor_date
  day_target = (defined?(@date) && @date.present?) ? @date.to_date : anchor_date

  week_target =
    if @current_view == :month && defined?(@week_anchor_date) && @week_anchor_date.present?
      @week_anchor_date.to_date
    else
      anchor_date.beginning_of_week(:monday)
    end

  two_weeks_target = week_target
  three_weeks_target = week_target

  list_from, list_to =
    case @current_view
    when :list
      [@period_start.to_date, @period_end.to_date]
    when :month
      [month_target.beginning_of_month, month_target.end_of_month]
    when :week, :two_weeks, :three_weeks
      [@period_start.to_date, @period_end.to_date]
    when :day
      [day_target, day_target]
    else
      [anchor_date, anchor_date + 29.days]
    end

  week_show_early_hours = defined?(@show_early_hours) && @show_early_hours
%>

<div class="flex flex-wrap items-center gap-3 mb-6">
  <%= link_to "Month", calendar_path(month: month_target.strftime("%Y-%m")), class: "#{@current_view == :month ? 'btn-primary' : 'text-brand-blue-600 hover:text-brand-red-600 transition'}" %>
  <%= link_to "Day", day_calendar_events_path(date: day_target), class: "#{@current_view == :day ? 'btn-primary' : 'text-brand-blue-600 hover:text-brand-red-600 transition'}" %>
  <%= link_to "Week", week_calendar_events_path(date: week_target, show_early_hours: week_show_early_hours), class: "#{@current_view == :week ? 'btn-primary' : 'text-brand-blue-600 hover:text-brand-red-600 transition'}" %>
  <%= link_to "2 Weeks", two_weeks_calendar_events_path(date: two_weeks_target), class: "#{@current_view == :two_weeks ? 'btn-primary' : 'text-brand-blue-600 hover:text-brand-red-600 transition'}" %>
  <%= link_to "3 Weeks", three_weeks_calendar_events_path(date: three_weeks_target), class: "#{@current_view == :three_weeks ? 'btn-primary' : 'text-brand-blue-600 hover:text-brand-red-600 transition'}" %>
  <%= link_to "List", list_calendar_events_path(from: list_from, to: list_to), class: "#{@current_view == :list ? 'btn-primary' : 'text-brand-blue-600 hover:text-brand-red-600 transition'}" %>
</div>
