<div class="container-wide py-12">
  <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-6">
    <h1 class="text-4xl font-bold">Calendar — Two Weeks</h1>
    <div class="flex items-center gap-3">
      <%= link_to "← Previous", two_weeks_calendar_events_path(date: (@period_start - 14.days)), class: "text-brand-blue-600 hover:text-brand-red-600 transition" %>
      <%= link_to "Current", two_weeks_calendar_events_path(date: Date.current), class: "text-brand-blue-600 hover:text-brand-red-600 transition" %>
      <%= link_to "Next →", two_weeks_calendar_events_path(date: (@period_start + 14.days)), class: "text-brand-blue-600 hover:text-brand-red-600 transition" %>
      <% if user_signed_in? %>
        <%= link_to "New Event", new_calendar_event_path, class: "btn-primary" %>
      <% end %>
    </div>
  </div>

  <%= render "view_tabs" %>

  <div class="bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-200 bg-gray-50">
      <h2 class="text-2xl font-semibold"><%= eu_date_range(@period_start, @period_end) %></h2>
    </div>

    <div class="grid grid-cols-7 border-b border-gray-200 bg-gray-50 text-sm font-semibold text-gray-700">
      <% ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"].each do |day_name| %>
        <div class="px-3 py-2 border-r border-gray-200 last:border-r-0"><%= day_name %></div>
      <% end %>
    </div>

    <div class="divide-y divide-gray-200">
      <% @days.each_slice(7) do |week_days| %>
        <div class="grid grid-cols-7">
          <% week_days.each do |day| %>
            <% day_events = @events_by_day[day] || [] %>
            <div class="min-h-44 p-3 border-r border-gray-200 last:border-r-0">
              <h3 class="text-sm font-semibold mb-2 <%= day == Date.current ? 'text-brand-red-600' : 'text-brand-blue-900' %>">
                <%= link_to eu_date(day, include_year: false, month: :short, weekday: :short), day_calendar_events_path(date: day), class: "hover:text-brand-red-600 transition" %>
              </h3>
              <% if day_events.any? %>
                <ul class="space-y-1">
                  <% day_events.each do |event| %>
                    <li>
                      <%= link_to calendar_event_path(event), class: "block rounded px-2 py-1 text-xs bg-brand-blue-50 hover:bg-brand-blue-100 text-brand-blue-800 transition" do %>
                        <span class="font-semibold"><%= eu_time(event.starts_at) %></span>
                        <span><%= event.title %></span>
                      <% end %>
                    </li>
                  <% end %>
                </ul>
              <% else %>
                <p class="text-xs text-gray-500">No events.</p>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>
