<%= form_with model: calendar_event do |form| %>
  <%= render "shared/form_errors", model: calendar_event %>

  <div class="space-y-6">
    <div>
      <%= form.label :title, "Title *", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.text_field :title, class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-brand-blue-600 focus:border-brand-blue-600" %>
      <%= field_error form, :title %>
    </div>

    <div>
      <%= form.label :location, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.text_field :location, class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-brand-blue-600 focus:border-brand-blue-600" %>
      <%= field_error form, :location %>
    </div>

    <div>
      <%= form.label :event_group_id, "Event Group", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.collection_select :event_group_id,
          @event_groups,
          :id,
          :name,
          { include_blank: "None" },
          class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-brand-blue-600 focus:border-brand-blue-600" %>
      <%= field_error form, :event_group_id %>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <%= form.label :starts_at, "Start *", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.datetime_local_field :starts_at, value: calendar_event.starts_at&.strftime("%Y-%m-%dT%H:%M"), class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-brand-blue-600 focus:border-brand-blue-600" %>
        <%= field_error form, :starts_at %>
      </div>

      <div>
        <%= form.label :ends_at, "End *", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.datetime_local_field :ends_at, value: calendar_event.ends_at&.strftime("%Y-%m-%dT%H:%M"), class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-brand-blue-600 focus:border-brand-blue-600" %>
        <%= field_error form, :ends_at %>
      </div>
    </div>

    <div>
      <%= form.label :color, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <div class="flex items-center gap-3" data-controller="color-override">
        <%= form.hidden_field :color, value: "" %>
        <label class="flex items-center gap-2 text-sm text-gray-600">
          <%= check_box_tag :color_override, "1", calendar_event.color.present?,
              data: { color_override_target: "enabled", action: "change->color-override#toggle" } %>
          Override color
        </label>
        <%= form.color_field :color, value: calendar_event.color.presence || "#000000",
            data: { color_override_target: "picker" },
            class: "h-10 w-14 border border-gray-300 rounded-lg p-1" %>
        <span class="text-sm text-gray-500">Leave unset to use the event group color</span>
      </div>
      <%= field_error form, :color %>
    </div>

    <div>
      <%= form.label :description, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.text_area :description, rows: 8, class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-brand-blue-600 focus:border-brand-blue-600" %>
      <%= field_error form, :description %>
    </div>

    <div class="flex gap-4">
      <%= form.submit class: "btn-primary" %>
      <%= link_to "Cancel", schedule_path, class: "text-brand-blue-600 hover:text-brand-red-600 transition px-4 py-2" %>
    </div>
  </div>
<% end %>
