<div class="container-wide py-12">
  <div class="mb-6">
    <%= link_to "← Back to Admin", dashboard_path, class: "text-brand-blue-600 hover:text-brand-red-600 transition" %>
  </div>

  <div class="flex justify-between items-center mb-8">
    <h1 class="text-4xl font-bold">Manage Menus</h1>
    <%= link_to "New Menu", new_menu_path, class: "bg-brand-blue-600 text-white px-6 py-2 rounded-lg hover:bg-brand-blue-700 transition" %>
  </div>

  <div class="space-y-6">
    <% @menus.each do |menu| %>
      <div class="bg-white border border-gray-200 rounded-lg p-6 shadow-sm">
        <div class="flex items-start justify-between gap-4">
          <div>
            <h2 class="text-2xl font-bold mb-2"><%= menu.name %></h2>
            <p class="text-sm text-gray-600">Location: <%= menu.location %></p>
            <p class="text-sm text-gray-600">Items: <%= menu.menu_items_count.to_i %></p>
          </div>

          <div class="flex gap-4 shrink-0">
            <%= link_to "Edit menu", edit_menu_path(menu), class: "text-brand-blue-600 hover:text-brand-red-600 transition" %>
            <%= link_to "Edit items", menu_menu_items_path(menu), class: "text-brand-blue-600 hover:text-brand-red-600 transition" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
