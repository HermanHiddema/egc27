<div class="container-wide py-12">
  <div class="mb-6">
    <%= link_to "← Calendar Events", admin_calendar_events_path, class: "text-brand-blue-600 hover:text-brand-red-600 transition" %>
  </div>

  <div class="bg-white border border-gray-200 rounded-lg p-8 shadow-sm max-w-3xl">
    <h1 class="text-3xl font-bold mb-6">Edit Calendar Event</h1>

    <% if @calendar_event.errors.any? %>
      <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-6">
        <p class="text-red-800 font-semibold"><%= pluralize(@calendar_event.errors.count, "error") %> prevented this event from being saved:</p>
        <ul class="list-disc list-inside text-red-700 mt-2">
          <% @calendar_event.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_with(model: [:admin, @calendar_event], local: true) do |form| %>
      <div class="space-y-4">
        <div>
          <%= form.label :title, class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= form.text_field :title, required: true, class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-brand-blue-600 focus:border-brand-blue-600" %>
        </div>

        <div>
          <%= form.label :description, class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= form.text_area :description, rows: 4, class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-brand-blue-600 focus:border-brand-blue-600" %>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <%= form.label :starts_at, class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= form.datetime_local_field :starts_at, required: true, class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-brand-blue-600 focus:border-brand-blue-600" %>
          </div>

          <div>
            <%= form.label :ends_at, class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= form.datetime_local_field :ends_at, required: true, class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-brand-blue-600 focus:border-brand-blue-600" %>
          </div>
        </div>

        <div>
          <%= form.label :location, class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= form.text_field :location, class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-brand-blue-600 focus:border-brand-blue-600" %>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <%= form.label :user_id, class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= form.collection_select :user_id, @users, :id, :display_name, { prompt: "Select a user" }, class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-brand-blue-600 focus:border-brand-blue-600" %>
          </div>

          <div>
            <%= form.label :event_group_id, class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= form.collection_select :event_group_id, @event_groups, :id, :name, { prompt: "Select a group" }, class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-brand-blue-600 focus:border-brand-blue-600" %>
          </div>
        </div>

        <div>
          <%= form.label :color, class: "block text-sm font-medium text-gray-700 mb-2" %>
          <div class="flex gap-2">
            <%= form.color_field :color, class: "w-16 h-10 border border-gray-300 rounded-lg cursor-pointer" %>
            <div class="flex-1 text-sm text-gray-600 pt-2">Optional override; leave empty to use event group color</div>
          </div>
        </div>
      </div>

      <div class="flex gap-3 mt-6">
        <%= form.submit "Update Event", class: "btn-primary" %>
        <%= link_to "Cancel", admin_calendar_events_path, class: "text-brand-blue-600 hover:text-brand-red-600 transition px-4 py-2" %>
      </div>
    <% end %>
  </div>
</div>
