<div class="container-wide py-12 space-y-6">
  <div class="flex justify-between items-center mb-8">
    <h1 class="text-4xl font-bold">Calendar Events</h1>
    <%= link_to "Add Event", new_admin_calendar_event_path, class: "btn-primary" %>
  </div>

  <div class="bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden">
    <% if @calendar_events.any? %>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200 text-sm">
        <thead class="bg-gray-50 border-b border-gray-200">
          <tr>
            <th class="px-6 py-3 text-left font-semibold text-gray-700">Title</th>
            <th class="px-6 py-3 text-left font-semibold text-gray-700">Group</th>
            <th class="px-6 py-3 text-left font-semibold text-gray-700">Starts At</th>
            <th class="px-6 py-3 text-left font-semibold text-gray-700">Ends At</th>
            <th class="px-6 py-3 text-left font-semibold text-gray-700">Color</th>
            <th class="px-6 py-3 text-left font-semibold text-gray-700">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100 bg-white">
          <% @calendar_events.each do |calendar_event| %>
            <tr class="hover:bg-gray-50 transition">
              <td class="px-6 py-4"><%= link_to calendar_event.title, edit_admin_calendar_event_path(calendar_event), class: "text-brand-blue-600 hover:text-brand-red-600" %></td>
              <td class="px-6 py-4 text-gray-700"><%= calendar_event.event_group&.name || "-" %></td>
              <td class="px-6 py-4 text-gray-700"><%= calendar_event.starts_at.strftime("%d %b %Y %H:%M") %></td>
              <td class="px-6 py-4 text-gray-700"><%= calendar_event.ends_at.strftime("%d %b %Y %H:%M") %></td>
              <td class="px-6 py-4">
                <% if calendar_event.color.present? %>
                  <span class="inline-block w-6 h-6 rounded" style="background-color: <%= calendar_event.color %>;" title="<%= calendar_event.color %>"></span>
                <% else %>
                  <span class="text-gray-500">-</span>
                <% end %>
              </td>
              <td class="px-6 py-4 text-right">
                <%= link_to "Edit", edit_admin_calendar_event_path(calendar_event), class: "text-brand-blue-600 hover:text-brand-red-600 transition mr-4" %>
                <%= button_to "Delete", admin_calendar_event_path(calendar_event), method: :delete, form: { class: "inline", data: { turbo_confirm: "Are you sure?" } }, class: "text-brand-red-600 hover:text-brand-red-800" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <% else %>
      <div class="text-center py-12 text-gray-500">
        <p class="mb-4">No calendar events yet.</p>
        <%= link_to "Create the first event", new_admin_calendar_event_path, class: "text-brand-blue-600 hover:text-brand-red-600" %>
      </div>
    <% end %>
  </div>
</div>
