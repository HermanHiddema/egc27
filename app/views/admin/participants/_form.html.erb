<%= form_with model: [:admin, participant], url: admin_participant_path(participant), method: :patch do |form| %>
  <%= render "shared/form_errors", model: participant, heading: "There were errors with this submission:" %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div>
      <%= form.label :first_name, "First name *", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.text_field :first_name, class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-brand-blue-600 focus:border-brand-blue-600" %>
      <%= field_error form, :first_name %>
    </div>

    <div>
      <%= form.label :last_name, "Last name *", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.text_field :last_name, class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-brand-blue-600 focus:border-brand-blue-600" %>
      <%= field_error form, :last_name %>
    </div>

    <div>
      <%= form.label :email, "Email *", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.email_field :email, readonly: true, class: "w-full border border-gray-300 rounded-lg px-4 py-2 bg-gray-50 text-gray-700", autocomplete: "off" %>
      <%= field_error form, :email %>
    </div>

    <div>
      <%= form.label :phone, "Phone", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.telephone_field :phone, class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-brand-blue-600 focus:border-brand-blue-600", placeholder: "+31612345678" %>
      <%= field_error form, :phone %>
    </div>

    <div>
      <%= form.label :gender, "Gender *", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.select :gender, options_for_select([["Male", "male"], ["Female", "female"], ["Non-Binary", "non_binary"], ["Prefer not to say", "prefer_not_to_say"]], participant.gender), { prompt: "Select gender" }, class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-brand-blue-600 focus:border-brand-blue-600" %>
      <%= field_error form, :gender %>
    </div>

    <div>
      <%= form.label :age_group, "Age group *", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.select :age_group, options_for_select([["0–11", "0-11"], ["12–17", "12-17"], ["18–49", "18-49"], ["50+", "50+"]], participant.age_group), { prompt: "Select age group" }, class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-brand-blue-600 focus:border-brand-blue-600" %>
      <%= field_error form, :age_group %>
    </div>

    <div>
      <%= form.label :country, "Country (ISO alpha-2) *", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.text_field :country, maxlength: 2, class: "w-full border border-gray-300 rounded-lg px-4 py-2 uppercase focus:ring-brand-blue-600 focus:border-brand-blue-600" %>
      <%= field_error form, :country %>
    </div>

    <div>
      <%= form.label :participant_type, "Participant type *", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.select :participant_type, options_for_select([["Player", "player"], ["Visitor", "visitor"]], participant.participant_type), {}, class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-brand-blue-600 focus:border-brand-blue-600" %>
      <%= field_error form, :participant_type %>
    </div>

    <div>
      <%= form.label :club, "Club", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.text_field :club, class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-brand-blue-600 focus:border-brand-blue-600" %>
      <%= field_error form, :club %>
    </div>

    <div>
      <%= form.label :rank, "Rank", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.select :rank, options_for_select([["None", ""]] + EgdGradeMapping.options_for_select, participant.rank), { prompt: "Select rank" }, class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-brand-blue-600 focus:border-brand-blue-600" %>
      <%= field_error form, :rank %>
    </div>

    <div>
      <%= form.label :egd_pin, "EGD PIN", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.text_field :egd_pin, class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-brand-blue-600 focus:border-brand-blue-600", inputmode: "numeric", autocomplete: "off" %>
      <%= field_error form, :egd_pin %>
    </div>

    <div>
      <%= form.label :rating, "Rating (EGD/GOR)", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.number_field :rating, readonly: true, class: "w-full border border-gray-300 rounded-lg px-4 py-2 bg-gray-50 text-gray-700" %>
      <%= field_error form, :rating %>
      <p class="mt-1 text-xs text-gray-500">Calculated automatically from the EGD entry or rank.</p>
    </div>

    <div>
      <%= form.label :attendance_option, "Attendance period", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.select :attendance_option, options_for_select([["All events", "all_events"], ["First week + weekend", "first_week_plus_weekend"], ["Weekend + second week", "weekend_plus_second_week"], ["Weekend only", "weekend_only"]], participant.attendance_option), { include_blank: "No change" }, class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-brand-blue-600 focus:border-brand-blue-600" %>
      <%= field_error form, :attendance_option %>
    </div>

    <div class="md:col-span-2">
      <fieldset class="space-y-2">
        <legend class="text-sm font-medium text-gray-900">Photo policy *</legend>
        <label class="flex items-start gap-3 text-sm text-gray-800">
          <%= form.radio_button :image_use_consent, true, class: "mt-1 h-4 w-4 border-gray-300 text-brand-blue-600 focus:ring-brand-blue-600" %>
          <span>Consents to the use of images.</span>
        </label>
        <label class="flex items-start gap-3 text-sm text-gray-800">
          <%= form.radio_button :image_use_consent, false, class: "mt-1 h-4 w-4 border-gray-300 text-brand-blue-600 focus:ring-brand-blue-600" %>
          <span>Does not consent to the use of images.</span>
        </label>
      </fieldset>
      <%= field_error form, :image_use_consent %>
    </div>
  </div>

  <div class="flex gap-4 mt-6">
    <%= form.submit "Save changes", class: "btn-primary" %>
    <%= link_to "Cancel", admin_participants_path, class: "text-neutral-700 hover:text-neutral-900 transition self-center" %>
  </div>
<% end %>
