<div class="container-wide py-12" data-controller="country-names">
  <div class="flex justify-between items-center mb-8">
    <h1 class="text-4xl font-bold">Participants (Admin)</h1>
    <p class="text-sm text-neutral-700"><strong><%= @participants.size %></strong> participant<%= "s" unless @participants.size == 1 %></p>
  </div>

  <div class="bg-white border border-gray-200 rounded-lg p-4 shadow-sm mb-4">
    <%= form_with url: admin_participants_path, method: :get, local: true, class: "flex flex-wrap items-end gap-3" do %>
      <div>
        <label for="country" class="block text-xs font-semibold uppercase tracking-wide text-neutral-700 mb-1">Country</label>
        <%= select_tag :country, options_for_select([["All countries", ""]] + @countries.map { |country| [country, country] }, @country_filter), class: "w-full rounded-md border border-neutral-300 bg-white px-3 py-2 text-sm text-neutral-900", data: { country_names_target: "select", action: "change->country-names#filter" } %>
      </div>
      <div>
        <label for="status" class="block text-xs font-semibold uppercase tracking-wide text-neutral-700 mb-1">Status</label>
        <%= select_tag :status, options_for_select([["All statuses", ""], ["Pending", "pending"], ["Confirmed", "confirmed"], ["Paid", "paid"]], @status_filter), class: "w-full rounded-md border border-neutral-300 bg-white px-3 py-2 text-sm text-neutral-900" %>
      </div>
      <%= hidden_field_tag :sort, @sort %>
      <%= hidden_field_tag :direction, @direction %>
      <%= submit_tag "Filter", class: "btn-primary" %>
    <% end %>
  </div>

  <% if @participants.any? %>
    <div class="bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-neutral-50">
            <tr>
              <% filters = { country: @country_filter, status: @status_filter } %>
              <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-neutral-700">
                <%= link_to "Name #{sort_indicator("name", @sort, @direction)}".strip, admin_participants_path(**filters, sort: "name", direction: next_sort_direction("name", @sort, @direction)), class: "hover:text-brand-red-700 transition" %>
              </th>
              <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-neutral-700">
                <%= link_to "Email #{sort_indicator("email", @sort, @direction)}".strip, admin_participants_path(**filters, sort: "email", direction: next_sort_direction("email", @sort, @direction)), class: "hover:text-brand-red-700 transition" %>
              </th>
              <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-neutral-700">
                <%= link_to "Country #{sort_indicator("country", @sort, @direction)}".strip, admin_participants_path(**filters, sort: "country", direction: next_sort_direction("country", @sort, @direction)), class: "hover:text-brand-red-700 transition" %>
              </th>
              <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-neutral-700">
                <%= link_to "Type #{sort_indicator("type", @sort, @direction)}".strip, admin_participants_path(**filters, sort: "type", direction: next_sort_direction("type", @sort, @direction)), class: "hover:text-brand-red-700 transition" %>
              </th>
              <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-neutral-700">
                <%= link_to "Status #{sort_indicator("status", @sort, @direction)}".strip, admin_participants_path(**filters, sort: "status", direction: next_sort_direction("status", @sort, @direction)), class: "hover:text-brand-red-700 transition" %>
              </th>
              <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wide text-neutral-700">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 bg-white">
            <% @participants.each do |participant| %>
              <tr>
                <td class="px-4 py-3 text-sm text-neutral-900"><%= [participant.first_name, participant.last_name].join(" ") %></td>
                <td class="px-4 py-3 text-sm text-neutral-700"><%= participant.email %></td>
                <td class="px-4 py-3 text-sm text-neutral-700" data-country-names-target="code" data-country-code="<%= participant.country %>"><%= country_with_flag(participant.country) %></td>
                <td class="px-4 py-3 text-sm text-neutral-700"><%= participant.participant_type&.capitalize %></td>
                <td class="px-4 py-3 text-sm">
                  <% status = participant.registration_status %>
                  <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium <%= participant_status_badge_class(status) %>"><%= status %></span>
                </td>
                <td class="px-4 py-3 text-sm text-right">
                  <%= link_to "Edit", edit_admin_participant_path(participant), class: "text-brand-red-600 hover:text-brand-red-700 transition" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% else %>
    <div class="bg-white border border-gray-200 rounded-lg p-8 shadow-sm">
      <p class="text-neutral-700">No participants match the selected filters.</p>
    </div>
  <% end %>
</div>
