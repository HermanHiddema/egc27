<div class="container-wide py-12 space-y-6">
  <div class="flex justify-between items-center mb-8">
    <h1 class="text-4xl font-bold">Event Groups</h1>
    <%= link_to "Add Group", new_admin_event_group_path, class: "btn-primary" %>
  </div>

  <div class="bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden">
  <% if @event_groups.any? %>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200 text-sm">
        <thead class="bg-gray-50 border-b border-gray-200">
          <tr>
            <th class="px-6 py-3 text-left font-semibold text-gray-700">Key</th>
            <th class="px-6 py-3 text-left font-semibold text-gray-700">Name</th>
            <th class="px-6 py-3 text-left font-semibold text-gray-700">Color</th>
            <th class="px-6 py-3 text-left font-semibold text-gray-700">Events</th>
            <th class="px-6 py-3 text-left font-semibold text-gray-700">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100 bg-white">
          <% @event_groups.each do |event_group| %>
            <tr class="hover:bg-gray-50 transition">
              <td class="px-6 py-4"><%= link_to event_group.key, edit_admin_event_group_path(event_group), class: "text-brand-blue-600 hover:text-brand-red-600" %></td>
              <td class="px-6 py-4 text-gray-700"><%= event_group.name %></td>
              <td class="px-6 py-4">
                <% if event_group.color.present? %>
                  <span class="inline-block w-6 h-6 rounded" style="background-color: <%= event_group.color %>;" title="<%= event_group.color %>"></span>
                <% else %>
                  <span class="text-gray-500">-</span>
                <% end %>
              </td>
              <td class="px-6 py-4 text-gray-700"><%= event_group.calendar_events.count %></td>
              <td class="px-6 py-4 text-right">
                <%= link_to "Edit", edit_admin_event_group_path(event_group), class: "text-brand-blue-600 hover:text-brand-red-600 transition mr-4" %>
                <%= button_to "Delete", admin_event_group_path(event_group), method: :delete, form: { class: "inline", data: { turbo_confirm: "Are you sure?" } }, class: "text-brand-red-600 hover:text-brand-red-800" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
      <div class="text-center py-12 text-gray-500">
        <p class="mb-4">No event groups yet.</p>
        <%= link_to "Create the first group", new_admin_event_group_path, class: "text-brand-blue-600 hover:text-brand-red-600" %>
      </div>
  <% end %>
  </div>
</div>
