<div class="container-wide py-12">
  <div class="mb-6">
    <%= link_to "← Back to Admin", admin_root_path, class: "text-brand-blue-600 hover:text-brand-red-600 transition" %>
  </div>

  <div class="flex justify-between items-center mb-8">
    <h1 class="text-4xl font-bold">Notices</h1>
    <div class="flex items-center gap-4">
      <p class="text-gray-600"><%= pluralize(@notices.length, "notice") %></p>
      <%= link_to "New Notice", new_admin_notice_path, class: "btn-primary" %>
    </div>
  </div>

  <div class="bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden">
    <table class="w-full text-sm">
      <thead class="bg-gray-50 border-b border-gray-200">
        <tr>
          <th class="px-6 py-3 text-left font-semibold text-gray-700">Title</th>
          <th class="px-6 py-3 text-left font-semibold text-gray-700">Body</th>
          <th class="px-6 py-3 text-left font-semibold text-gray-700">Active</th>
          <th class="px-6 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @notices.each do |notice| %>
          <tr class="hover:bg-gray-50">
            <td class="px-6 py-4"><%= notice.title.presence || "—" %></td>
            <td class="px-6 py-4 text-gray-600 max-w-md truncate"><%= notice.body %></td>
            <td class="px-6 py-4">
              <% if notice.active? %>
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-800">Yes</span>
              <% else %>
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-600">No</span>
              <% end %>
            </td>
            <td class="px-6 py-4 text-right">
              <div class="inline-flex items-center gap-3">
                <%= link_to "Edit", edit_admin_notice_path(notice), class: "text-brand-blue-600 hover:text-brand-red-600 transition" %>
                <%= button_to "Delete", admin_notice_path(notice), method: :delete, data: { turbo_confirm: "Are you sure you want to delete this notice?" }, class: "text-brand-red-600 hover:text-brand-red-700 transition" %>
              </div>
            </td>
          </tr>
        <% end %>
        <% if @notices.empty? %>
          <tr>
            <td colspan="4" class="px-6 py-8 text-center text-gray-500">No notices yet.</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
