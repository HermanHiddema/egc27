<div class="min-h-screen flex items-center justify-center bg-neutral-50 py-12 px-4 sm:px-6 lg:px-8">
  <div class="max-w-md w-full space-y-8">
    <div>
      <h2 class="mt-6 text-center text-3xl font-bold">Sign in with a magic link</h2>
      <p class="mt-2 text-center text-sm text-neutral-600">Enter your email and we'll send you a one-time sign-in link.</p>
    </div>

    <% if notice.present? %>
      <div class="rounded-md bg-green-50 p-4">
        <p class="text-sm font-medium text-green-800"><%= notice %></p>
      </div>
    <% end %>

    <% if alert.present? %>
      <div class="rounded-md bg-red-50 p-4">
        <p class="text-sm font-medium text-red-800"><%= alert %></p>
      </div>
    <% end %>

    <form method="post" action="<%= user_magic_link_session_path %>" class="space-y-6">
      <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">

      <div>
        <label for="user_email" class="sr-only">Email address</label>
        <input type="email" id="user_email" name="user[email]" required
          class="appearance-none rounded relative block w-full px-3 py-2 border border-neutral-300 placeholder-neutral-500 text-neutral-900 focus:outline-none focus:ring-brand-blue-500 focus:border-brand-blue-500 sm:text-sm"
          placeholder="Email address" autofocus="autofocus" autocomplete="email">
      </div>

      <div>
        <button type="submit" class="group relative w-full flex justify-center py-2 px-4 border border-transparent text-sm font-medium rounded-md text-white bg-brand-blue-600 hover:bg-brand-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-brand-blue-500">
          Send magic link
        </button>
      </div>

      <p class="mt-2 text-center text-sm text-neutral-600">
        Prefer to use a password?
        <%= link_to "Sign in with password", new_user_session_path, class: "font-medium text-brand-blue-600 hover:text-brand-blue-500" %>
      </p>
    </form>
  </div>
</div>
