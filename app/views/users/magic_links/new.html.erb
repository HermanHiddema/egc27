<div class="container-wide py-12">
  <div class="max-w-md mx-auto card-elevated p-8">
    <div class="text-center mb-6">
      <h1 class="text-2xl font-bold text-brand-blue-900">Sign in with a magic link</h1>
      <p class="mt-2 text-sm text-neutral-600">Enter your email and we'll send you a one-time sign-in link.</p>
    </div>

    <form method="post" action="<%= user_magic_link_session_path %>" class="space-y-6">
      <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">

      <div>
        <label for="user_email" class="block text-sm font-medium text-neutral-700 mb-2">Email address *</label>
        <input type="email" id="user_email" name="user[email]" required
          class="block w-full border border-neutral-300 rounded-lg px-4 py-2 text-neutral-900 focus:outline-none focus:ring-2 focus:ring-brand-blue-500 focus:border-brand-blue-500"
          placeholder="Email address" autofocus="autofocus" autocomplete="email">
      </div>

      <%= render "shared/turnstile_widget" %>

      <button type="submit" class="btn-primary w-full">Send magic link</button>

      <p class="text-center text-sm text-neutral-600">
        Prefer to use a password?
        <%= link_to "Sign in with password", new_user_session_path, class: "font-medium text-brand-blue-600 hover:text-brand-blue-500" %>
      </p>
    </form>
  </div>
</div>
