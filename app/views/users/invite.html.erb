<div class="container-wide py-12">
  <div class="mb-6">
    <%= link_to "← Back to Users", users_path, class: "text-brand-blue-600 hover:text-brand-red-600 transition" %>
  </div>

  <div class="bg-white border border-gray-200 rounded-lg p-8 shadow-sm">
    <h1 class="text-3xl font-bold mb-2">Invite User</h1>
    <p class="text-sm text-neutral-600 mb-6">We'll email an invitation so they can confirm their account and set their own password.</p>

    <%= form_with model: @user, url: send_invitation_user_path, method: :post do |form| %>
      <% if @user.errors.any? %>
        <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-6">
          <h2 class="text-red-800 font-semibold mb-2">There were errors with your submission:</h2>
          <ul class="text-red-700 list-disc list-inside">
            <% @user.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="space-y-6">
        <div>
          <%= form.label :full_name, "Display name", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= form.text_field :full_name, class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-brand-blue-600 focus:border-brand-blue-600" %>
        </div>

        <div>
          <%= form.label :email, class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= form.email_field :email, class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-brand-blue-600 focus:border-brand-blue-600" %>
        </div>

        <div>
          <%= form.label :role, class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= form.select :role,
                          options_for_select(User::ROLES.map { |role| [role.titleize, role] }, @user.role),
                          {},
                          class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-brand-blue-600 focus:border-brand-blue-600" %>
        </div>

        <div class="flex gap-4">
          <%= form.submit "Send invitation", class: "btn-primary" %>
          <%= link_to "Cancel", users_path, class: "text-brand-blue-600 hover:text-brand-red-600 transition px-4 py-2" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
