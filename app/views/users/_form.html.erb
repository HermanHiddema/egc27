<%= form_with model: user, url: user_path(user), method: :patch do |form| %>
  <% if user.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-6">
      <h2 class="text-red-800 font-semibold mb-2">There were errors with your submission:</h2>
      <ul class="text-red-700 list-disc list-inside">
        <% user.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="space-y-6">
    <div>
      <%= form.label :full_name, "Display name", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.text_field :full_name, class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-brand-blue-600 focus:border-brand-blue-600" %>
    </div>

    <div>
      <%= form.label :email, "Email *", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.email_field :email, class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-brand-blue-600 focus:border-brand-blue-600" %>
    </div>

    <% if current_user.admin? %>
      <div>
        <%= form.label :role, class: "block text-sm font-medium text-gray-700 mb-2" %>
        <% disable_role_change = current_user == user && user.admin? %>
        <%= form.select :role,
                        options_for_select(User::ROLES.map { |role| [role.titleize, role] }, user.role),
                        {},
                        class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-brand-blue-600 focus:border-brand-blue-600",
                        disabled: disable_role_change %>
        <% if disable_role_change %>
          <p class="text-sm text-gray-600 mt-2">You cannot remove your own admin role.</p>
        <% end %>
      </div>
    <% end %>

    <% if current_user.admin? %>
      <div>
        <%= form.label :password, "New password", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.password_field :password, autocomplete: "new-password", class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-brand-blue-600 focus:border-brand-blue-600" %>
        <p class="text-sm text-gray-600 mt-2">Leave blank to keep the current password.</p>
      </div>

      <div>
        <%= form.label :password_confirmation, class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.password_field :password_confirmation, autocomplete: "new-password", class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-brand-blue-600 focus:border-brand-blue-600" %>
      </div>
    <% end %>

    <div class="flex gap-4">
      <%= form.submit "Save User", class: "btn-primary" %>
      <%= link_to "Cancel", users_path, class: "text-brand-blue-600 hover:text-brand-red-600 transition px-4 py-2" %>
    </div>
  </div>
<% end %>
