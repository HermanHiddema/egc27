<div class="container-wide py-12">
  <% if resource.password_set? %>
    <!-- Standard edit form for existing users -->
    <div class="mb-6">
  <%= link_to "← Back", root_path, class: "text-brand-blue-600 hover:text-brand-red-600 transition" %>
    </div>

    <div class="bg-white border border-gray-200 rounded-lg p-8 shadow-sm max-w-md mx-auto">
      <h1 class="text-3xl font-bold mb-6">Edit Account</h1>

      <%= form_with model: resource, as: resource_name, url: registration_path(resource_name), method: :patch, local: true do |form| %>
        <%= render "shared/form_errors", model: resource %>

        <div class="space-y-6">
          <div>
            <%= form.label :full_name, "Display name", class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= form.text_field :full_name, class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-brand-blue-600 focus:border-brand-blue-600" %>
            <%= field_error form, :full_name %>
          </div>

          <div>
            <%= form.label :email, "Email *", class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= form.email_field :email, class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-brand-blue-600 focus:border-brand-blue-600" %>
            <%= field_error form, :email %>
          </div>

          <div>
            <%= form.label :password, "New password (leave blank to keep current)", class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= form.password_field :password, 
                autocomplete: "new-password",
                class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-brand-blue-600 focus:border-brand-blue-600" %>
            <%= field_error form, :password %>
          </div>

          <div>
            <%= form.label :password_confirmation, class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= form.password_field :password_confirmation, 
                autocomplete: "new-password",
                class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-brand-blue-600 focus:border-brand-blue-600" %>
            <%= field_error form, :password_confirmation %>
          </div>

          <div>
            <%= form.label :current_password, "Current password *", class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= form.password_field :current_password, 
                autocomplete: "current-password",
                class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-brand-blue-600 focus:border-brand-blue-600" %>
            <%= field_error form, :current_password %>
            <p class="text-sm text-gray-600 mt-2">We need your current password to confirm your changes.</p>
          </div>

          <div class="flex gap-4">
            <%= form.submit "Save Changes", class: "btn-primary" %>
            <%= link_to "Back", root_path, class: "text-brand-blue-600 hover:text-brand-red-600 transition px-4 py-2" %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <!-- Simplified password form for newly confirmed users -->
    <div class="bg-white border border-gray-200 rounded-lg p-8 shadow-sm max-w-md mx-auto">
      <h1 class="text-3xl font-bold mb-2">Welcome!</h1>
      <p class="text-gray-600 mb-6">Your email has been confirmed. Now let's set up your password.</p>
      <p class="text-sm text-gray-600 mb-6">You do not have a password yet. Set one here to enable password sign-in.</p>

      <%= form_with model: resource, as: resource_name, url: registration_path(resource_name), method: :patch, local: true do |form| %>
        <%= render "shared/form_errors", model: resource %>

        <div class="space-y-6">
          <div>
            <%= form.label :password, "Password *", class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= form.password_field :password, 
                autocomplete: "new-password",
                placeholder: "Enter a strong password",
                class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-brand-blue-600 focus:border-brand-blue-600" %>
            <%= field_error form, :password %>
            <p class="text-sm text-gray-600 mt-2">At least 6 characters</p>
          </div>

          <div>
            <%= form.label :password_confirmation, "Confirm password *", class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= form.password_field :password_confirmation, 
                autocomplete: "new-password",
                placeholder: "Confirm your password",
                class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-brand-blue-600 focus:border-brand-blue-600" %>
            <%= field_error form, :password_confirmation %>
          </div>

          <div>
            <%= form.submit "Set Password & Continue", class: "btn-primary w-full" %>
          </div>
        </div>
      <% end %>

      <% if resource.participants.exists? %>
        <div class="mt-6 pt-6 border-t border-gray-200">
          <%= button_to "Skip for now", skip_user_password_path, method: :post,
              class: "btn-secondary w-full" %>
          <p class="text-sm text-gray-600 mt-2 text-center">You can sign in later with a magic link sent to your email.</p>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
