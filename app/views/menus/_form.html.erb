<%= form_with model: menu do |form| %>
  <%= render "shared/form_errors", model: menu %>

  <div class="space-y-6">
    <div>
      <%= form.label :name, "Name *", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.text_field :name, class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-brand-blue-600 focus:border-brand-blue-600" %>
      <%= field_error form, :name %>
    </div>

    <div>
      <%= form.label :location, "Location *", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.text_field :location, placeholder: "header", class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-brand-blue-600 focus:border-brand-blue-600" %>
      <%= field_error form, :location %>
    </div>

    <div class="flex items-center gap-2">
      <%= form.check_box :active, class: "rounded border-gray-300 text-brand-blue-600 focus:ring-brand-blue-600" %>
      <%= form.label :active, class: "text-sm font-medium text-gray-700" %>
    </div>
    <%= field_error form, :active %>

    <div class="flex gap-4">
      <%= form.submit class: "btn-primary" %>
      <%= link_to "Cancel", menus_path, class: "text-brand-blue-600 hover:text-brand-red-600 transition px-4 py-2" %>
    </div>
  </div>
<% end %>
