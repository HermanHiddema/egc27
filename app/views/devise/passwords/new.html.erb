<div class="container-wide py-12">
  <div class="max-w-md mx-auto card-elevated p-8">
    <div class="text-center mb-6">
      <h1 class="text-2xl font-bold text-brand-blue-900">Forgot your password?</h1>
      <p class="mt-2 text-sm text-neutral-600">Enter your email and we'll send you password reset instructions.</p>
    </div>

    <%= form_with model: resource, scope: resource_name, url: password_path(resource_name), method: :post, class: "space-y-6" do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div>
        <%= f.label :email, "Email *", class: "block text-sm font-medium text-neutral-700 mb-2" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "block w-full border border-neutral-300 rounded-lg px-4 py-2 text-neutral-900 focus:outline-none focus:ring-2 focus:ring-brand-blue-500 focus:border-brand-blue-500" %>
      </div>

      <%= render "shared/turnstile_widget" %>

      <%= f.submit "Send me reset instructions", class: "btn-primary w-full" %>
    <% end %>

    <p class="mt-6 text-center text-sm text-neutral-600">
      Remembered your password?
      <%= link_to "Sign in", new_session_path(resource_name), class: "font-medium text-brand-blue-600 hover:text-brand-blue-500" %>
    </p>
  </div>
</div>
