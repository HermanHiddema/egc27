<div class="container-wide py-12">
  <div class="max-w-md mx-auto card-elevated p-8">
    <div class="text-center mb-6">
      <h1 class="text-2xl font-bold text-brand-blue-900">Change your password</h1>
      <p class="mt-2 text-sm text-neutral-600">Choose a new password for your account.</p>
    </div>

    <%= form_with model: resource, scope: resource_name, url: password_path(resource_name), method: :put, class: "space-y-6" do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>
      <%= f.hidden_field :reset_password_token %>

      <div>
        <%= f.label :password, "New password", class: "block text-sm font-medium text-neutral-700 mb-2" %>
        <%= f.password_field :password, autofocus: true, autocomplete: "new-password", class: "block w-full border border-neutral-300 rounded-lg px-4 py-2 text-neutral-900 focus:outline-none focus:ring-2 focus:ring-brand-blue-500 focus:border-brand-blue-500" %>
        <% if @minimum_password_length %>
          <p class="mt-2 text-sm text-neutral-600"><%= @minimum_password_length %> characters minimum.</p>
        <% end %>
      </div>

      <div>
        <%= f.label :password_confirmation, "Confirm new password", class: "block text-sm font-medium text-neutral-700 mb-2" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "block w-full border border-neutral-300 rounded-lg px-4 py-2 text-neutral-900 focus:outline-none focus:ring-2 focus:ring-brand-blue-500 focus:border-brand-blue-500" %>
      </div>

      <%= f.submit "Change my password", class: "btn-primary w-full" %>
    <% end %>
  </div>
</div>
