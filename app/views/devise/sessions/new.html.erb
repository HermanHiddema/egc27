<div class="container-wide py-12">
  <div class="max-w-md mx-auto card-elevated p-8">
    <div class="text-center mb-6">
      <h1 class="text-2xl font-bold text-brand-blue-900">Sign in to your account</h1>
    </div>

    <form method="post" action="<%= session_path(resource_name) %>" class="space-y-6">
      <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">

      <div>
        <label for="user_email" class="block text-sm font-medium text-neutral-700 mb-2">Email address</label>
        <input type="email" id="user_email" name="user[email]" required class="block w-full border border-neutral-300 rounded-lg px-4 py-2 text-neutral-900 focus:outline-none focus:ring-2 focus:ring-brand-blue-500 focus:border-brand-blue-500" placeholder="Email address" autofocus="autofocus" autocomplete="email">
      </div>

      <div>
        <label for="user_password" class="block text-sm font-medium text-neutral-700 mb-2">Password</label>
        <input type="password" id="user_password" name="user[password]" required class="block w-full border border-neutral-300 rounded-lg px-4 py-2 text-neutral-900 focus:outline-none focus:ring-2 focus:ring-brand-blue-500 focus:border-brand-blue-500" placeholder="Password" autocomplete="current-password">
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="flex items-center justify-between">
          <div class="flex items-center">
            <input type="checkbox" id="user_remember_me" name="user[remember_me]" class="h-4 w-4 text-brand-blue-600 focus:ring-brand-blue-500 border-neutral-300 rounded">
            <label for="user_remember_me" class="ml-2 block text-sm text-neutral-700">Remember me</label>
          </div>

          <% if devise_mapping.recoverable? %>
            <div class="text-sm">
              <%= link_to "Forgot your password?", new_password_path(resource_name), class: "font-medium text-brand-blue-600 hover:text-brand-blue-500" %>
            </div>
          <% end %>
        </div>
      <% end %>

      <button type="submit" class="btn-primary w-full">Sign in</button>
    </form>

    <div class="mt-6 pt-6 border-t border-gray-200">
      <p class="text-sm text-gray-600 mb-3 text-center">Didn't set a password yet?</p>
      <%= button_to "Sign in with a magic link", new_user_magic_link_session_path, method: :get, class: "btn-secondary w-full" %>
    </div>
  </div>
</div>
