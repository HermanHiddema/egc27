<div class="container-wide py-12">
  <div class="max-w-md mx-auto card-elevated p-8">
    <div class="text-center mb-6">
      <h1 class="text-2xl font-bold text-brand-blue-900">Create your account</h1>
      <p class="mt-2 text-sm text-neutral-600">Sign up to get started.</p>
    </div>

    <%= form_with model: resource, scope: resource_name, url: registration_path(resource_name), class: "space-y-6" do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div>
        <%= f.label :full_name, "Display name", class: "block text-sm font-medium text-neutral-700 mb-2" %>
        <%= f.text_field :full_name, autocomplete: "name", class: "block w-full border border-neutral-300 rounded-lg px-4 py-2 text-neutral-900 focus:outline-none focus:ring-2 focus:ring-brand-blue-500 focus:border-brand-blue-500" %>
      </div>

      <div>
        <%= f.label :email, class: "block text-sm font-medium text-neutral-700 mb-2" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "block w-full border border-neutral-300 rounded-lg px-4 py-2 text-neutral-900 focus:outline-none focus:ring-2 focus:ring-brand-blue-500 focus:border-brand-blue-500" %>
      </div>

      <div>
        <%= f.label :password, class: "block text-sm font-medium text-neutral-700 mb-2" %>
        <%= f.password_field :password, autocomplete: "new-password", class: "block w-full border border-neutral-300 rounded-lg px-4 py-2 text-neutral-900 focus:outline-none focus:ring-2 focus:ring-brand-blue-500 focus:border-brand-blue-500" %>
        <% if @minimum_password_length %>
          <p class="mt-2 text-sm text-neutral-600"><%= @minimum_password_length %> characters minimum.</p>
        <% end %>
      </div>

      <div>
        <%= f.label :password_confirmation, class: "block text-sm font-medium text-neutral-700 mb-2" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "block w-full border border-neutral-300 rounded-lg px-4 py-2 text-neutral-900 focus:outline-none focus:ring-2 focus:ring-brand-blue-500 focus:border-brand-blue-500" %>
      </div>

      <%= f.submit "Sign up", class: "btn-primary w-full" %>
    <% end %>

    <p class="mt-6 text-center text-sm text-neutral-600">
      Already have an account?
      <%= link_to "Sign in", new_session_path(resource_name), class: "font-medium text-brand-blue-600 hover:text-brand-blue-500" %>
    </p>
  </div>
</div>
