<div class="container-wide py-12">
  <div class="max-w-md mx-auto card-elevated p-8">
    <h1 class="text-2xl font-bold text-brand-blue-900 mb-6">Edit Account</h1>

    <%= form_with model: resource, scope: resource_name, url: registration_path(resource_name), method: :put, class: "space-y-6" do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div>
        <%= f.label :full_name, "Display name", class: "block text-sm font-medium text-neutral-700 mb-2" %>
        <%= f.text_field :full_name, autocomplete: "name", class: "block w-full border border-neutral-300 rounded-lg px-4 py-2 text-neutral-900 focus:outline-none focus:ring-2 focus:ring-brand-blue-500 focus:border-brand-blue-500" %>
      </div>

      <div>
        <%= f.label :email, "Email *", class: "block text-sm font-medium text-neutral-700 mb-2" %>
        <%= f.email_field :email, autocomplete: "email", class: "block w-full border border-neutral-300 rounded-lg px-4 py-2 text-neutral-900 focus:outline-none focus:ring-2 focus:ring-brand-blue-500 focus:border-brand-blue-500" %>
      </div>

      <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
        <p class="text-sm text-neutral-600">Currently waiting confirmation for: <%= resource.unconfirmed_email %></p>
      <% end %>

      <div>
        <%= f.label :password, "New password", class: "block text-sm font-medium text-neutral-700 mb-2" %>
        <%= f.password_field :password, autocomplete: "new-password", class: "block w-full border border-neutral-300 rounded-lg px-4 py-2 text-neutral-900 focus:outline-none focus:ring-2 focus:ring-brand-blue-500 focus:border-brand-blue-500" %>
        <% if resource.password_set? %>
          <p class="text-sm text-neutral-600 mt-2">Leave blank if you don't want to change it.</p>
        <% else %>
          <p class="text-sm text-neutral-600 mt-2">You do not have a password yet. Set one here to enable password sign-in.</p>
        <% end %>
      </div>

      <div>
        <%= f.label :password_confirmation, class: "block text-sm font-medium text-neutral-700 mb-2" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "block w-full border border-neutral-300 rounded-lg px-4 py-2 text-neutral-900 focus:outline-none focus:ring-2 focus:ring-brand-blue-500 focus:border-brand-blue-500" %>
      </div>

      <% if resource.password_set? %>
        <div>
          <%= f.label :current_password, "Current password *", class: "block text-sm font-medium text-neutral-700 mb-2" %>
          <%= f.password_field :current_password, autocomplete: "current-password", class: "block w-full border border-neutral-300 rounded-lg px-4 py-2 text-neutral-900 focus:outline-none focus:ring-2 focus:ring-brand-blue-500 focus:border-brand-blue-500" %>
          <p class="text-sm text-neutral-600 mt-2">We need your current password to confirm changes.</p>
        </div>
      <% end %>

      <div class="flex items-center gap-4">
        <%= f.submit "Update Account", class: "btn-primary" %>
        <%= link_to "Cancel", root_path, class: "font-medium text-brand-blue-600 hover:text-brand-red-600 transition px-4 py-2" %>
      </div>
    <% end %>
  </div>
</div>
