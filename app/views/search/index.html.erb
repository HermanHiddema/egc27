<% content_for :title, "Search" %>

<div class="container-wide py-12">
  <h1 class="text-4xl font-bold mb-8">Search</h1>

  <%= form_with url: search_path, method: :get, class: "mb-10" do |form| %>
    <div class="flex gap-2">
      <%= form.search_field :q,
            value: @query,
            placeholder: "Search pages and articles...",
            autofocus: true,
            aria: { label: "Search query" },
            class: "flex-1 border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-brand-blue-500" %>
      <%= form.submit "Search", class: "btn-primary" %>
    </div>
  <% end %>

  <% if @query.present? %>
    <% results_count = @pages.size + @articles.size %>

    <% if results_count.zero? %>
      <p class="text-xl text-neutral-500">No results found for "<%= @query %>".</p>
    <% else %>
      <p class="text-sm text-gray-600 mb-8">
        <%= pluralize(results_count, "result") %> for "<%= @query %>"
      </p>

      <% if @pages.any? %>
        <section class="mb-12">
          <h2 class="text-2xl font-bold mb-4">Pages</h2>
          <div class="space-y-4">
            <% @pages.each do |page| %>
              <div class="bg-white border border-gray-200 rounded-lg p-6 shadow-sm">
                <h3 class="text-xl font-bold mb-1">
                  <%= link_to page.title, page_path(page), class: "hover:text-brand-red-600 transition" %>
                </h3>
                <p class="text-sm text-gray-600">/<%= page.slug %></p>
              </div>
            <% end %>
          </div>
        </section>
      <% end %>

      <% if @articles.any? %>
        <section class="mb-12">
          <h2 class="text-2xl font-bold mb-4">News</h2>
          <div class="space-y-4">
            <% @articles.each do |article| %>
              <div class="bg-white border border-gray-200 rounded-lg p-6 shadow-sm">
                <h3 class="text-xl font-bold mb-1">
                  <%= link_to article.title, article_path(article), class: "hover:text-brand-red-600 transition" %>
                </h3>
                <p class="text-sm text-gray-600"><%= article.created_at.strftime("%d %B %Y") %></p>
              </div>
            <% end %>
          </div>
        </section>
      <% end %>
    <% end %>
  <% end %>
</div>
