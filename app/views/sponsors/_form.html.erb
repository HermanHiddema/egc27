<%= form_with model: sponsor do |form| %>
  <%= render "shared/form_errors", model: sponsor %>

  <div class="space-y-6">
    <div>
      <%= form.label :name, "Name *", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.text_field :name, class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-brand-blue-600 focus:border-brand-blue-600" %>
      <%= field_error form, :name %>
    </div>

    <div>
      <%= form.label :website, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.url_field :website, placeholder: "https://example.org", class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-brand-blue-600 focus:border-brand-blue-600" %>
      <%= field_error form, :website %>
    </div>

    <div>
      <%= form.label :description, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.text_area :description, rows: 5, class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-brand-blue-600 focus:border-brand-blue-600" %>
      <%= field_error form, :description %>
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-700 mb-2">Social media links</label>
      <div class="space-y-3">
        <% Sponsor::SOCIAL_MEDIA_PLATFORMS.each do |key, label| %>
          <div>
            <%= label_tag "sponsor_social_media_links_#{key}", label, class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= text_field_tag "sponsor[social_media_links][#{key}]",
                               sponsor.social_media_links&.[](key),
                               id: "sponsor_social_media_links_#{key}",
                               placeholder: "https://",
                               class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-brand-blue-600 focus:border-brand-blue-600" %>
          </div>
        <% end %>
      </div>
    </div>

    <div>
      <%= form.label :logo, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.file_field :logo, accept: "image/*", class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-brand-blue-600 focus:border-brand-blue-600" %>
      <%= field_error form, :logo %>
      <% if sponsor.logo.attached? %>
        <p class="text-sm text-gray-600 mt-2">A logo is currently attached.</p>
      <% end %>
    </div>

    <div class="flex gap-4">
      <%= form.submit "Save Sponsor", class: "btn-primary" %>
      <%= link_to "Cancel", sponsors_path, class: "text-brand-blue-600 hover:text-brand-red-600 transition px-4 py-2" %>
    </div>
  </div>
<% end %>
