<div class="container py-12">
  <div class="max-w-2xl mx-auto">
    <div class="flex justify-between items-center mb-8">
      <h1 class="text-4xl font-bold">Registration Confirmed</h1>
    </div>

    <div class="bg-white border border-gray-200 rounded-lg p-8 shadow-sm space-y-6">
      <div>
        <h2 class="text-lg font-semibold text-neutral-900 mb-4">Registration Details</h2>
        <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-3 text-sm">
          <div>
            <dt class="font-medium text-neutral-700">Name</dt>
            <dd class="text-neutral-900"><%= "#{@participant.first_name} #{@participant.last_name}" %></dd>
          </div>
          <div>
            <dt class="font-medium text-neutral-700">Country</dt>
            <dd class="text-neutral-900"><%= "#{country_flag_emoji(@participant.country)} #{@participant.country}".strip %></dd>
          </div>
          <% if @participant.club.present? %>
            <div>
              <dt class="font-medium text-neutral-700">Club</dt>
              <dd class="text-neutral-900"><%= @participant.club %></dd>
            </div>
          <% end %>
          <% if @participant.rank_grade.present? %>
            <div>
              <dt class="font-medium text-neutral-700">Rank</dt>
              <dd class="text-neutral-900"><%= @participant.rank_grade %></dd>
            </div>
          <% end %>
          <% if @participant.rating.present? %>
            <div>
              <dt class="font-medium text-neutral-700">Rating</dt>
              <dd class="text-neutral-900"><%= @participant.rating %></dd>
            </div>
          <% end %>
          <div>
            <dt class="font-medium text-neutral-700">Attendance</dt>
            <dd class="text-neutral-900"><%= @participant.attendance_option&.humanize || "—" %></dd>
          </div>
        </dl>
      </div>

      <% if !@participant.confirmed? %>
        <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4">
          <p class="text-yellow-800 text-sm">
            <strong>Please check your email</strong> — a confirmation link has been sent to your email address. You must confirm your registration before you can complete payment.
          </p>
        </div>
      <% elsif @participant.confirmed? && @participant.visitor? %>
        <div class="bg-green-50 border border-green-200 rounded-lg p-4">
          <p class="text-green-800 text-sm">
            <strong>Your registration is confirmed.</strong> No payment is required for visitor registrations.
          </p>
        </div>
      <% else %>
        <div class="bg-green-50 border border-green-200 rounded-lg p-4">
          <p class="text-green-800 text-sm">
            <strong>Your registration is confirmed.</strong>
          </p>
        </div>
        <div>
          <%= link_to "Proceed to Payment", new_participant_payment_path(@participant), class: "btn-primary" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
