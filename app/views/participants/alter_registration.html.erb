<div class="container-wide py-12">
  <div class="max-w-md mx-auto card-elevated p-8">
    <div class="text-center mb-6">
      <h1 class="text-2xl font-bold text-brand-blue-900">Confirm your email address</h1>
      <p class="mt-2 text-sm text-neutral-600">Your registration is not yet confirmed. Please confirm your email address to continue.</p>
    </div>

    <%= form_with url: user_confirmation_path, method: :post, class: "space-y-6" do |f| %>
      <%= hidden_field_tag "user[email]", @email %>

      <%= render "shared/turnstile_widget" %>

      <%= f.submit "Resend my email confirmation", class: "btn-primary w-full" %>
    <% end %>
  </div>
</div>
