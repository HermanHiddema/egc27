<div class="container-wide py-12">
  <div class="flex justify-between items-center mb-8 gap-4">
    <div>
      <h1 class="text-4xl font-bold">My registrations</h1>
      <p class="mt-2 text-neutral-700">View the participant registrations attached to your account.</p>
    </div>
    <%= link_to "Register another participant", new_participant_path, class: "btn-primary" %>
  </div>

  <% if @participants.any? %>
    <div class="bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-neutral-50">
            <tr>
              <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-neutral-700">Name</th>
              <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-neutral-700">Country</th>
              <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-neutral-700">Type</th>
              <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-neutral-700">Status</th>
              <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-neutral-700"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 bg-white">
            <% @participants.each do |participant| %>
              <tr>
                <td class="px-4 py-3 text-sm text-neutral-900"><%= [participant.first_name, participant.last_name].join(" ") %></td>
                <td class="px-4 py-3 text-sm text-neutral-700"><%= country_with_flag(participant.country) %></td>
                <td class="px-4 py-3 text-sm text-neutral-700"><%= participant.participant_type.humanize %></td>
                <td class="px-4 py-3 text-sm text-neutral-700"><%= participant.confirmed? ? "Confirmed" : "Pending confirmation" %></td>
                <td class="px-4 py-3 text-sm text-right">
                  <%= link_to "View", participant_path(participant), class: "text-brand-red-600 hover:text-brand-red-700 transition" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% else %>
    <div class="bg-white border border-gray-200 rounded-lg p-8 shadow-sm">
      <p class="text-neutral-700 mb-4">No registrations are linked to your account yet.</p>
      <%= link_to "Register now", new_participant_path, class: "btn-primary" %>
    </div>
  <% end %>
</div>