<%= form_with model: notice do |form| %>
  <%= render "shared/form_errors", model: notice %>

  <div class="space-y-6">
    <div>
      <%= form.label :title, "Title *", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.text_field :title, class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-brand-blue-600 focus:border-brand-blue-600" %>
      <%= field_error form, :title %>
    </div>

    <div>
      <%= form.label :body, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.text_area :body, rows: 4, class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-brand-blue-600 focus:border-brand-blue-600" %>
      <%= field_error form, :body %>
    </div>

    <div class="flex items-center gap-3">
      <%= form.check_box :active, class: "h-4 w-4 rounded border-gray-300 text-brand-blue-600 focus:ring-brand-blue-600" %>
      <%= form.label :active, "Active (shown on front page)", class: "text-sm font-medium text-gray-700" %>
    </div>
    <%= field_error form, :active %>

    <div class="flex gap-4">
      <%= form.submit class: "btn-primary" %>
      <%= link_to "Cancel", notices_path, class: "text-brand-blue-600 hover:text-brand-red-600 transition px-4 py-2" %>
    </div>
  </div>
<% end %>
