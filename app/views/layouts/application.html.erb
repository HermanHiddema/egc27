<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "EGC 2027" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Egc27">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag "tailwind", "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <%# Load Cloudflare Turnstile only on pages that render a widget %>
    <% if content_for?(:turnstile_script) && ENV["CLOUDFLARE_TURNSTILE_SITE_KEY"].present? %>
      <script>function egc27TurnstileOnLoad() { window.dispatchEvent(new CustomEvent("turnstile:load")) }</script>
      <script src="https://challenges.cloudflare.com/turnstile/v0/api.js?onload=egc27TurnstileOnLoad&render=explicit" async defer></script>
    <% end %>

    <%# Load TinyMCE only on pages that render the TinyMCE editor %>
    <% if content_for?(:tinymce_script) %>
      <script src="<%= tinymce_script_url %>"></script>
    <% end %>
  </head>

  <body class="min-h-screen flex flex-col overflow-x-clip bg-cover bg-center bg-fixed bg-no-repeat" style="background-image: url('<%= asset_path("StJansKathedraal.webp") %>');">
    <!-- Header -->
    <header class="bg-brand-red-600 border-b border-brand-yellow-800 sticky top-0 z-50 shadow-sm" data-controller="header-shrink" data-header-shrink-threshold-value="24" data-header-shrink-hysteresis-value="16">
      <nav class="container-wide flex items-center justify-between h-48 lg:h-48 transition-all duration-300" data-header-shrink-target="nav">
        <div class="flex items-center gap-2">
          <%= link_to image_tag("EGC-logo.svg", alt: "EGC 2027 Logo", class: "h-32 lg:h-48 w-auto transition-all duration-300", data: { header_shrink_target: "logo" }), root_path %>
          <div class="hidden lg:block">
            <%= link_to root_path, class: "text-3xl lg:text-4xl font-bold text-brand-yellow-600 hover:text-brand-yellow-700 transition-all duration-300", data: { header_shrink_target: "title" } do -%>
<span class="md:hidden">EGC 2027</span><span class="hidden md:inline">European Go Congress</span>
            <% end %>
            <p class="hidden md:block text-sm text-brand-yellow-300">'s Hertogenbosch, the Netherlands, 24 July - 8 August, 2027</p>
          </div>
        </div>

        <div class="flex flex-col items-end gap-1 lg:flex-row lg:items-center lg:gap-4">
          <%= link_to "Newsletter", newsletter_path, class: "btn-primary bg-green-600 hover:bg-green-700 focus:ring-green-500" %>
          <%= link_to new_participant_path, class: "btn-primary bg-green-600 hover:bg-green-700 focus:ring-green-500" do %>
            <span class="lg:hidden">Register</span><span class="hidden lg:inline">Register now</span>
          <% end %>
          <% if defined?(current_user) && (current_user.present? || !devise_controller?) %>
            <% if current_user.present? %>
              <div class="relative" data-controller="dropdown">
                <button class="btn-primary flex items-center gap-1"
                        type="button"
                        data-dropdown-target="toggle"
                        aria-controls="user-menu"
                        aria-expanded="false"
                        aria-haspopup="true">
                  <span><%= current_user.display_name %></span>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                  </svg>
                </button>

                <div id="user-menu" data-dropdown-target="menu" class="absolute right-0 mt-0 w-48 bg-brand-red-600 border border-brand-yellow-800 rounded-md shadow-lg hidden z-50">
                  <%= link_to "Account", edit_user_registration_path, class: "block px-4 py-2 text-sm text-brand-yellow-300 hover:text-brand-yellow-400 transition-colors" %>
                  <% if (registration_link = user_registration_menu_link(current_user)) %>
                    <%= link_to registration_link[:label], registration_link[:path], class: "block px-4 py-2 text-sm text-brand-yellow-300 hover:text-brand-yellow-400 transition-colors" %>
                  <% end %>
                  <% if current_user.admin? %>
                    <%= link_to "Admin", dashboard_path, class: "block px-4 py-2 text-sm text-brand-yellow-300 hover:text-brand-yellow-400 transition-colors" %>
                  <% end %>
                  <%= button_to "Sign out",
                                destroy_user_session_path,
                                method: :delete,
                                form_class: "w-full",
                                class: "w-full text-left px-4 py-2 text-sm text-brand-yellow-300 hover:text-brand-yellow-400 transition-colors bg-transparent border-0" %>
                </div>
              </div>
            <% else %>
              <%= link_to "Sign in", new_user_session_path, class: "btn-primary" %>
            <% end %>
          <% end %>
        </div>
      </nav>
    </header>

    <!-- Menu Bar -->
    <%= render "layouts/menu", menu: @header_menu, root_items: @header_menu_root_items %>

    <div class="flex-1" style="background-color: color-mix(in srgb, var(--brand-yellow-600) 78%, transparent);">
      <!-- Flash Messages -->
      <% flash.each do |type, message| %>
        <div class="container-wide mt-4">
          <div class="p-4 rounded-lg <%= type.to_s == 'notice' ? 'bg-green-50 text-green-800 border border-green-200' : 'bg-red-50 text-red-800 border border-red-200' %>">
            <% if type.to_s == "notice" %>
              <%= sanitize(message.to_s, tags: %w[a], attributes: %w[href class rel data-turbo-method data-turbo-confirm]) %>
            <% else %>
              <%= message %>
            <% end %>
          </div>
        </div>
      <% end %>

      <!-- Main Content -->
      <main class="pt-8 pb-24">
        <%= yield %>
      </main>
    </div>

    <!-- Footer -->
    <footer class="bg-brand-blue-900 text-white">
      <div class="container-wide py-12">
        <div class="border-t border-brand-blue-800 pt-8 flex items-start justify-between gap-4">
          <div class="grid grid-cols-2 gap-3 sm:flex sm:gap-4">
            <a href="https://www.facebook.com/share/189m4UBKsN/?mibextid=wwXIfr" target="_blank" rel="noopener noreferrer" class="text-neutral-400 hover:text-brand-yellow-400 transition-colors" aria-label="Facebook">
              <%= social_media_icon("facebook", css_class: "w-6 h-6") %>
            </a>
            <a href="https://www.instagram.com/egc2027?igsh=eGlzeTN0MWJtZmc5&utm_source=qr" target="_blank" rel="noopener noreferrer" class="text-neutral-400 hover:text-brand-yellow-400 transition-colors" aria-label="Instagram">
              <%= social_media_icon("instagram", css_class: "w-6 h-6") %>
            </a>
            <a href="https://x.com/egc2027?s=21" target="_blank" rel="noopener noreferrer" class="text-neutral-400 hover:text-brand-yellow-400 transition-colors" aria-label="X (Twitter)">
              <%= social_media_icon("x", css_class: "w-6 h-6") %>
            </a>
            <a href="https://discord.gg/m8cpSVbhMY" target="_blank" rel="noopener noreferrer" class="text-neutral-400 hover:text-brand-yellow-400 transition-colors" aria-label="Discord">
              <%= social_media_icon("discord", css_class: "w-6 h-6") %>
            </a>
            <a href="https://chat.whatsapp.com/LPdN50HJlFaFvcaRVhmkPC" target="_blank" rel="noopener noreferrer" class="text-neutral-400 hover:text-brand-yellow-400 transition-colors" aria-label="WhatsApp">
              <%= social_media_icon("whatsapp", css_class: "w-6 h-6") %>
            </a>
          </div>

          <%= render "layouts/footer_menu", menu: @footer_menu, root_items: @footer_menu_root_items || [] %>
        </div>
      </div>
    </footer>

  </body>
</html>
