<% if ENV["CLOUDFLARE_TURNSTILE_SITE_KEY"].present? %>
  <% content_for :head do %>
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
  <% end %>
<% end %>

<div class="container-wide py-12">
  <div class="max-w-4xl mx-auto card p-6">
    <h1 class="text-3xl font-bold mb-2">Newsletter</h1>
    <p class="text-neutral-700 mb-6">Leave your details to receive updates. You can unsubscribe at any time.</p>

    <% if @newsletter_subscription&.errors&.any? %>
      <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-4">
        <h2 class="text-red-800 font-semibold mb-2">There were errors with your submission:</h2>
        <ul class="text-red-700 list-disc list-inside">
          <% @newsletter_subscription.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_with model: @newsletter_subscription, url: newsletter_subscriptions_path, class: "grid grid-cols-1 md:grid-cols-4 gap-4 items-end" do |form| %>
      <div>
        <%= form.label :first_name, "First name", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.text_field :first_name, class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-brand-blue-600 focus:border-brand-blue-600", autocomplete: "given-name", required: true %>
      </div>
      <div>
        <%= form.label :last_name, "Last name", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.text_field :last_name, class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-brand-blue-600 focus:border-brand-blue-600", autocomplete: "family-name", required: true %>
      </div>
      <div>
        <%= form.label :email, "Email", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.email_field :email, class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-brand-blue-600 focus:border-brand-blue-600", autocomplete: "email", required: true %>
      </div>
      <div>
        <%= form.submit "Subscribe", class: "btn-primary w-full" %>
      </div>
      <div class="md:col-span-4">
        <%= render "shared/turnstile_widget" %>
      </div>
    <% end %>
  </div>
</div>
