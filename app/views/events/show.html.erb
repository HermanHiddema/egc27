<div class="container-wide py-12">
  <div class="mb-6">
    <%= link_to "← Back to Calendar", calendar_path(month: @event.starts_at.strftime("%Y-%m")), class: "text-brand-blue-600 hover:text-brand-red-600 transition" %>
  </div>

  <article class="bg-white border border-gray-200 rounded-lg p-8 shadow-sm">
    <header class="mb-8">
      <h1 class="text-4xl font-bold mb-4"><%= @event.title %></h1>
      <div class="text-sm text-gray-600 border-b border-gray-200 pb-4 space-y-1">
        <div>
          <span class="font-semibold">Starts:</span>
          <%= eu_datetime(@event.starts_at) %>
        </div>
        <div>
          <span class="font-semibold">Ends:</span>
          <%= eu_datetime(@event.ends_at) %>
        </div>
        <% if @event.location.present? %>
          <div>
            <span class="font-semibold">Location:</span>
            <%= @event.location %>
          </div>
        <% end %>
        <div>
          <span class="font-semibold">Created by:</span>
          <%= @event.user.display_name %>
        </div>
      </div>
    </header>

    <% if @event.description.present? %>
      <div class="prose max-w-none text-gray-700 whitespace-pre-wrap mb-8"><%= @event.description %></div>
    <% end %>

    <% if user_signed_in? %>
      <div class="flex gap-4">
        <%= link_to "Edit", edit_event_path(@event), class: "text-brand-blue-600 hover:text-brand-red-600 transition" %>
        <%= button_to "Delete", @event, method: :delete, data: { turbo_confirm: "Are you sure you want to delete this event?" }, class: "text-brand-red-600 hover:text-brand-red-700 transition" %>
      </div>
    <% end %>
  </article>
</div>
