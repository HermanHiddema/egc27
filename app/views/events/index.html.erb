<div class="container-wide py-12">
  <div class="flex justify-between items-center mb-8">
    <h1 class="text-4xl font-bold">Events</h1>
    <% if current_user&.can_create? %>
      <%= link_to "New Event", new_event_path, class: "btn-primary" %>
    <% end %>
  </div>

  <% if @events.any? %>
    <div class="space-y-4">
      <% @events.each do |event| %>
        <div class="bg-white border border-gray-200 rounded-lg p-6 shadow-sm">
          <div class="flex justify-between items-start">
            <div>
              <h2 class="text-2xl font-bold mb-1">
                <%= link_to event.title, event, class: "hover:text-brand-red-600 transition" %>
              </h2>
              <div class="text-sm text-gray-600 space-y-1">
                <div>
                  <span class="font-semibold">Start:</span>
                  <%= eu_datetime(event.starts_at) %>
                </div>
                <div>
                  <span class="font-semibold">End:</span>
                  <%= eu_datetime(event.ends_at) %>
                </div>
                <% if event.location.present? %>
                  <div>
                    <span class="font-semibold">Location:</span>
                    <%= event.location %>
                  </div>
                <% end %>
              </div>
            </div>
            <div class="text-sm text-gray-500 text-right">
              <%= pluralize(event.event_registrations.size, "registration") %>
            </div>
          </div>

          <% if event.description.present? %>
            <p class="text-gray-700 mt-3 line-clamp-2"><%= event.description %></p>
          <% end %>

          <div class="flex gap-4 mt-4">
            <%= link_to "View", event, class: "text-brand-blue-600 hover:text-brand-red-600 transition" %>
            <% if current_user&.can_edit? %>
              <%= link_to "Edit", edit_event_path(event), class: "text-brand-blue-600 hover:text-brand-red-600 transition" %>
            <% end %>
            <% if current_user&.can_delete? %>
              <%= button_to "Delete", event, method: :delete, data: { turbo_confirm: "Are you sure you want to delete this event?" }, class: "text-brand-red-600 hover:text-brand-red-700 transition" %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="bg-white border border-gray-200 rounded-lg p-8 shadow-sm">
      <p class="text-neutral-700">No events have been added yet.</p>
    </div>
  <% end %>
</div>
