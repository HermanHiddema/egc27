<div class="container-wide py-12">
  <div class="max-w-3xl mx-auto">
    <h1 class="text-4xl font-bold mb-2">Your cart</h1>
    <p class="mt-2 text-neutral-700 mb-8">
      Review the items waiting to be paid. By default all items are selected;
      uncheck any you do not want to pay for right now.
    </p>

    <% if @orders.any? %>
      <%= form_with url: checkout_cart_path, method: :post, data: { turbo: false } do |f| %>
        <div class="bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden mb-6">
          <ul class="divide-y divide-gray-100">
            <% @orders.each do |order| %>
              <li class="flex items-center justify-between gap-4 px-4 py-4">
                <label class="flex items-center gap-3 cursor-pointer">
                  <%= check_box_tag "order_ids[]", order.id, true,
                        id: "order_#{order.id}",
                        class: "h-4 w-4 text-brand-red-600 border-gray-300 rounded" %>
                  <span>
                    <span class="text-sm text-neutral-900"><%= order.description %></span>
                    <span class="block text-xs text-neutral-500">Order <%= order.order_number %></span>
                  </span>
                </label>
                <span class="text-sm font-semibold text-neutral-900 whitespace-nowrap">
                  <%= order.amount_formatted %>
                </span>
              </li>
            <% end %>
          </ul>
        </div>

        <div class="flex items-center justify-between">
          <p class="text-sm text-neutral-600">
            You will be redirected to Mollie's secure payment page.
          </p>
          <%= f.submit "Pay selected items via Mollie", class: "btn-primary py-3 px-6 text-lg" %>
        </div>
      <% end %>
    <% else %>
      <div class="bg-white border border-gray-200 rounded-lg p-8 shadow-sm">
        <p class="text-neutral-700">Your cart is empty.</p>
      </div>
    <% end %>
  </div>
</div>
