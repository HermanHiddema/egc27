<div class="container-wide py-12">
  <div class="mb-6">
    <%= link_to "← Back to News", articles_path, class: "text-brand-blue-600 hover:text-brand-red-600 transition" %>
  </div>

  <article class="bg-white border border-gray-200 rounded-lg p-8 shadow-sm">
    <header class="mb-8">
      <h1 class="text-4xl font-bold mb-4"><%= @article.title %></h1>
      <div class="flex items-center justify-between text-sm text-gray-600 border-b border-gray-200 pb-4">
        <div>
          Posted by <%= @article.user.display_name %> on <%= eu_datetime(@article.created_at, twelve_hour: true) %>
        </div>
        <% if user_signed_in? %>
          <div class="flex gap-4">
            <%= link_to "Edit", edit_article_path(@article), class: "text-brand-blue-600 hover:text-brand-red-600 transition" %>
            <%= button_to "Delete", @article, method: :delete, data: { turbo_confirm: "Are you sure you want to delete this article?" }, class: "text-brand-red-600 hover:text-brand-red-700 transition" %>
          </div>
        <% end %>
      </div>
    </header>

    <div class="rich-content max-w-none">
      <%= render_rich_html(@article.content) %>
    </div>
  </article>
</div>