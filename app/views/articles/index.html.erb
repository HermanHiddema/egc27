<div class="container-wide py-12">
  <div class="flex justify-between items-center mb-8">
    <h1 class="text-4xl font-bold">News</h1>
    <% if current_user&.can_create? %>
      <%= link_to "New Article", new_article_path, class: "bg-brand-blue-600 text-white px-6 py-2 rounded-lg hover:bg-brand-blue-700 transition" %>
    <% end %>
  </div>

  <div class="space-y-8">
    <% @articles.each do |article| %>
      <div class="bg-white border border-gray-200 rounded-lg p-6 shadow-sm">
        <div class="mb-4">
          <h2 class="text-2xl font-bold mb-2">
            <%= link_to article.title, article, class: "hover:text-brand-red-600 transition" %>
          </h2>
          <div class="text-sm text-gray-600">
            Posted by <%= article.user.display_name %> on <%= eu_datetime(article.created_at, twelve_hour: true) %>
          </div>
        </div>

        <% if article.main_image.attached? && article.main_image.image? %>
          <div class="mb-4">
            <%= image_tag main_image_representation(article.main_image, resize_to_limit: [320, 144]), alt: "#{article.title} main image", class: "h-36 w-full max-w-xs object-cover rounded-lg border border-gray-200" %>
          </div>
        <% end %>

        <div class="rich-content trix-content text-gray-700 mb-4 line-clamp-3">
          <%= article.content %>
        </div>

        <div class="flex gap-4">
          <%= link_to "Read More", article, class: "text-brand-blue-600 hover:text-brand-red-600 transition" %>
          <% if current_user&.can_edit? %>
            <%= link_to "Edit", edit_article_path(article), class: "text-brand-blue-600 hover:text-brand-red-600 transition" %>
          <% end %>
          <% if current_user&.can_delete? %>
            <%= button_to "Delete", article, method: :delete, data: { turbo_confirm: "Are you sure?" }, class: "text-brand-red-600 hover:text-brand-red-700 transition" %>
          <% end %>
        </div>
      </div>
    <% end %>

    <% if @articles.empty? %>
      <div class="text-center text-gray-500 py-12">
        <p class="text-xl">No news articles yet.</p>
        <% if current_user&.can_create? %>
          <p class="mt-4">
            <%= link_to "Create the first article", new_article_path, class: "text-brand-blue-600 hover:text-brand-red-600 transition" %>
          </p>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
