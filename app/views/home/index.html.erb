<div class="container-wide py-12">
  <div class="card p-6 mb-8">
    <h2 class="text-2xl font-bold mb-2">Newsletter</h2>
    <p class="text-neutral-700 mb-4">Leave your details to receive updates. You can unsubscribe at any time.</p>

    <% if @newsletter_subscription&.errors&.any? %>
      <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-4">
        <h3 class="text-red-800 font-semibold mb-2">There were errors with your submission:</h3>
        <ul class="text-red-700 list-disc list-inside">
          <% @newsletter_subscription.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_with model: @newsletter_subscription, url: newsletter_subscriptions_path, class: "grid grid-cols-1 md:grid-cols-4 gap-4 items-end" do |form| %>
      <div>
        <%= form.label :first_name, "First name", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.text_field :first_name, class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-brand-blue-600 focus:border-brand-blue-600", autocomplete: "given-name", required: true %>
      </div>
      <div>
        <%= form.label :last_name, "Last name", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.text_field :last_name, class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-brand-blue-600 focus:border-brand-blue-600", autocomplete: "family-name", required: true %>
      </div>
      <div>
        <%= form.label :email, "Email", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.email_field :email, class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-brand-blue-600 focus:border-brand-blue-600", autocomplete: "email", required: true %>
      </div>
      <div>
        <%= form.submit "Subscribe", class: "btn-primary w-full" %>
      </div>
    <% end %>
  </div>

  <div class="flex justify-between items-center mb-8">
    <h1 class="text-4xl font-bold">Recent News</h1>
    <div class="flex items-center gap-4">
      <%= link_to "Register As Participant", new_participant_path, class: "btn-primary" %>
      <%= link_to "View All News", articles_path, class: "text-brand-blue-600 hover:text-brand-red-600 transition font-medium" %>
    </div>
  </div>

  <% if @recent_articles.any? %>
    <div class="space-y-6">
      <% @recent_articles.each do |article| %>
        <div class="card p-6">
          <div class="mb-4">
            <h2 class="text-2xl font-bold mb-2">
              <%= link_to article.title, article_path(article), class: "hover:text-brand-red-600 transition" %>
            </h2>
            <div class="text-sm text-neutral-600">
              Posted by <%= article.user.display_name %> on <%= eu_datetime(article.created_at, twelve_hour: true) %>
            </div>
          </div>

          <div class="rich-content trix-content text-neutral-700 mb-4 line-clamp-3">
            <%= article.content %>
          </div>

          <div class="flex gap-4">
            <%= link_to "Read More →", article_path(article), class: "text-brand-blue-600 hover:text-brand-red-600 transition font-medium" %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-12">
      <p class="text-xl text-neutral-500 mb-4">No news articles yet.</p>
      <% if current_user&.can_create? %>
        <%= link_to "Create the first article", new_article_path, class: "btn-primary" %>
      <% end %>
    </div>
  <% end %>
</div>
