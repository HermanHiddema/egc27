<div class="container-wide py-12">
  <div class="flex justify-between items-center mb-8">
    <h1 class="text-4xl font-bold">Recent News</h1>
    <div class="flex items-center gap-4">
      <%= link_to "Register As Participant", new_participant_path, class: "btn-primary" %>
      <%= link_to "View All News", articles_path, class: "text-brand-blue-600 hover:text-brand-red-600 transition font-medium" %>
    </div>
  </div>

  <% if @recent_articles.any? %>
    <div class="space-y-6">
      <% @recent_articles.each_with_index do |article, index| %>
        <div class="card p-0 overflow-hidden">
          <% has_image = article.main_image.attached? && article.main_image.image? %>
          <% image_on_left = index.even? %>
          <% content_side_padding = if has_image
                                      image_on_left ? "sm:pl-72" : "sm:pr-72"
                                    else
                                      ""
                                    end %>

          <div class="relative">
            <% if has_image %>
              <% image_side_class = image_on_left ? "sm:left-0" : "sm:right-0" %>
              <div class="w-full sm:w-64 sm:absolute sm:top-0 sm:bottom-0 <%= image_side_class %>">
                <%= image_tag main_image_representation(article.main_image, resize_to_limit: [512, 512]), alt: "#{article.title} main image", class: "h-40 w-full sm:h-full object-cover" %>
              </div>
            <% end %>

            <div class="p-6 <%= content_side_padding %>">
              <div class="mb-4">
                <h2 class="text-2xl font-bold mb-2">
                  <%= link_to article.title, article_path(article), class: "hover:text-brand-red-600 transition" %>
                </h2>
                <div class="text-sm text-neutral-600">
                  Posted by <%= article.user.display_name %> on <%= eu_datetime(article.created_at, twelve_hour: true) %>
                </div>
              </div>

              <div class="rich-content trix-content text-neutral-700 mb-4 line-clamp-3">
                <%= article.content %>
              </div>

              <div class="flex gap-4">
                <%= link_to "Read More →", article_path(article), class: "text-brand-blue-600 hover:text-brand-red-600 transition font-medium" %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-12">
      <p class="text-xl text-neutral-500 mb-4">No news articles yet.</p>
      <% if current_user&.can_create? %>
        <%= link_to "Create the first article", new_article_path, class: "btn-primary" %>
      <% end %>
    </div>
  <% end %>
</div>
