<div class="container-wide py-12">
  <div class="flex flex-col lg:flex-row gap-6">
    <%# Left sidebar (1/4 width) %>
    <aside class="lg:w-1/4 shrink-0 space-y-6">
      <div>
        <%= image_tag "EGC2027-goborddraakje2.png", alt: "EGC 2027 mascot", class: "w-full h-auto object-cover", loading: "lazy", decoding: "async" %>
      </div>

      <%= link_to "Register As Participant", new_participant_path, class: "btn-primary block w-full text-center" %>

      <% if @recent_participants.any? %>
        <div class="bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden">
          <div class="px-4 py-3 border-b border-gray-200 bg-neutral-50">
            <h2 class="text-sm font-semibold uppercase tracking-wide text-neutral-700">Recently Registered</h2>
          </div>
          <ul class="divide-y divide-gray-100">
            <% @recent_participants.each do |participant| %>
              <li class="px-4 py-2 flex justify-between items-center gap-2">
                <span class="text-sm text-neutral-900"><%= [participant.first_name, participant.last_name].join(" ") %></span>
                <span class="text-xs text-neutral-500 whitespace-nowrap"><%= participant.rank_grade.presence || "–" %></span>
              </li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <% if @sponsors.any? %>
        <div class="bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden">
          <div class="px-4 py-3 border-b border-gray-200 bg-neutral-50">
            <h2 class="text-sm font-semibold uppercase tracking-wide text-neutral-700">Our Sponsors</h2>
          </div>
          <div class="p-4" data-controller="sponsor-carousel">
            <% @sponsors.each_with_index do |sponsor, index| %>
              <div data-sponsor-carousel-target="slide" class="<%= "hidden" unless index.zero? %>">
                <% logo_source = main_image_representation(sponsor.logo, resize_to_limit: [256, 256]) || sponsor.logo %>
                <% sponsor_logo = image_tag(logo_source, alt: "#{sponsor.name} logo", class: "h-full w-full object-contain p-4", loading: "lazy", decoding: "async") %>
                <% sponsor_logo_square = content_tag(:div, sponsor_logo, class: "relative mx-auto aspect-square w-full max-w-56 overflow-hidden") %>
                <% if sponsor.website.present? %>
                  <%= link_to sponsor_logo_square, sponsor.website, target: "_blank", rel: "noopener noreferrer", class: "block" %>
                <% else %>
                  <%= sponsor_logo_square %>
                <% end %>
                <p class="mt-2 text-center text-sm text-neutral-700"><%= sponsor.name %></p>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </aside>

    <%# Main content (3/4 width) %>
    <div class="lg:w-3/4 flex-1 space-y-8">
      <% if @notices.any? %>
        <div class="space-y-3">
          <% @notices.each do |notice| %>
            <div class="bg-[#fff94d] border border-[#e8df00] rounded-lg p-4">
              <div class="flex justify-between items-start gap-4">
                <div class="flex-1">
                  <p class="font-semibold text-[#5f4f00] mb-1"><%= notice.title %></p>
                  <% if notice.body.present? %>
                    <p class="text-[#6f5f00]"><%= notice.body %></p>
                  <% end %>
                </div>
                <% if current_user&.admin? %>
                  <div class="flex items-center gap-2 flex-shrink-0">
                    <%= link_to edit_notice_path(notice), title: "Edit notice", "aria-label": "Edit notice", class: "text-[#6f5f00] hover:text-[#4f4200] transition" do %>
                      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                        <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z"></path>
                      </svg>
                    <% end %>
                    <%= button_to deactivate_notice_path(notice), method: :patch, title: "Deactivate notice", "aria-label": "Deactivate notice", class: "text-[#6f5f00] hover:text-[#4f4200] transition", form_class: "inline" do %>
                      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                        <path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd"></path>
                      </svg>
                    <% end %>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>

      <div>
        <div class="flex justify-between items-center mb-8">
          <h1 class="text-4xl font-bold">Recent News</h1>
          <div class="flex items-center gap-4">
            <%= link_to "View All News", articles_path, class: "text-brand-blue-600 hover:text-brand-red-600 transition font-medium" %>
          </div>
        </div>

        <% if @recent_articles.any? %>
          <div class="space-y-6">
            <% @recent_articles.each_with_index do |article, index| %>
              <div class="card p-0 overflow-hidden">
                <% has_image = article.main_image.attached? && article.main_image.variable? %>
                <% image_on_left = index.even? %>
                <% card_media_height_class = has_image ? "sm:min-h-64" : "" %>
                <% content_side_padding = if has_image
                                            image_on_left ? "sm:pl-72" : "sm:pr-72"
                                          else
                                            ""
                                          end %>

                <div class="relative <%= card_media_height_class %>">
                  <% if has_image %>
                    <% image_side_class = image_on_left ? "sm:left-0" : "sm:right-0" %>
                    <div class="relative w-full aspect-square sm:w-64 sm:absolute sm:top-0 <%= image_side_class %>">
                      <%= image_tag main_image_representation(article.main_image, resize_to_limit: [512, 512]), alt: "#{article.title} main image", class: "h-full w-full object-cover" %>
                      <div class="absolute inset-x-0 bottom-0 p-4 sm:hidden bg-gradient-to-t from-black/75 via-black/30 to-transparent">
                        <h2 class="text-2xl font-bold text-white" style="text-shadow: 0 2px 6px rgba(0, 0, 0, 0.95); -webkit-text-stroke: 1px rgba(0, 0, 0, 0.55);">
                          <%= link_to article.title, article_path(article), class: "hover:text-brand-red-200 transition" %>
                        </h2>
                      </div>
                    </div>
                  <% end %>

                  <div class="p-6 <%= content_side_padding %>">
                    <div class="mb-4 <%= has_image ? "hidden sm:block" : "block" %>">
                      <h2 class="text-2xl font-bold mb-2">
                        <%= link_to article.title, article_path(article), class: "hover:text-brand-red-600 transition" %>
                      </h2>
                      <div class="text-sm text-neutral-600">
                        Posted by <%= article.user.display_name %> on <%= eu_datetime(article.created_at, twelve_hour: true) %>
                      </div>
                    </div>

                    <div class="rich-content trix-content text-neutral-700 mb-4 line-clamp-3">
                      <%= article.content %>
                    </div>

                    <div class="flex gap-4">
                      <%= link_to "Read More →", article_path(article), class: "text-brand-blue-600 hover:text-brand-red-600 transition font-medium" %>
                    </div>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="text-center py-12">
            <p class="text-xl text-neutral-500 mb-4">No news articles yet.</p>
            <% if current_user&.can_create? %>
              <%= link_to "Create the first article", new_article_path, class: "btn-primary" %>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
