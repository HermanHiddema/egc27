<div class="container-wide py-12">
  <% if @notices.any? %>
    <div class="mb-8 space-y-3">
      <% @notices.each do |notice| %>
        <div class="bg-brand-blue-50 border border-brand-blue-200 rounded-lg p-4">
          <% if notice.title.present? %>
            <p class="font-semibold text-brand-blue-900 mb-1"><%= notice.title %></p>
          <% end %>
          <p class="text-brand-blue-800"><%= notice.body %></p>
        </div>
      <% end %>
    </div>
  <% end %>

  <div class="flex justify-between items-center mb-8">
    <h1 class="text-4xl font-bold">Recent News</h1>
    <div class="flex items-center gap-4">
      <%= link_to "Register As Participant", new_participant_path, class: "btn-primary" %>
      <%= link_to "View All News", articles_path, class: "text-brand-blue-600 hover:text-brand-red-600 transition font-medium" %>
    </div>
  </div>

  <% if @recent_articles.any? %>
    <div class="space-y-6">
      <% @recent_articles.each_with_index do |article, index| %>
        <div class="card p-0 overflow-hidden">
          <% has_image = article.main_image.attached? && article.main_image.variable? %>
          <% image_on_left = index.even? %>
          <% content_side_padding = if has_image
                                      image_on_left ? "sm:pl-72" : "sm:pr-72"
                                    else
                                      ""
                                    end %>

          <div class="relative">
            <% if has_image %>
              <% image_side_class = image_on_left ? "sm:left-0" : "sm:right-0" %>
              <div class="relative w-full aspect-square sm:aspect-auto sm:w-64 sm:h-auto sm:absolute sm:top-0 sm:bottom-0 <%= image_side_class %>">
                <%= image_tag main_image_representation(article.main_image, resize_to_limit: [512, 512]), alt: "#{article.title} main image", class: "h-full w-full sm:h-full object-cover" %>
                <div class="absolute inset-x-0 bottom-0 p-4 sm:hidden bg-gradient-to-t from-black/75 via-black/30 to-transparent">
                  <h2 class="text-2xl font-bold text-white" style="text-shadow: 0 2px 6px rgba(0, 0, 0, 0.95); -webkit-text-stroke: 1px rgba(0, 0, 0, 0.55);">
                    <%= link_to article.title, article_path(article), class: "hover:text-brand-red-200 transition" %>
                  </h2>
                </div>
              </div>
            <% end %>

            <div class="p-6 <%= content_side_padding %>">
              <div class="mb-4 <%= has_image ? "hidden sm:block" : "block" %>">
                <h2 class="text-2xl font-bold mb-2">
                  <%= link_to article.title, article_path(article), class: "hover:text-brand-red-600 transition" %>
                </h2>
                <div class="text-sm text-neutral-600">
                  Posted by <%= article.user.display_name %> on <%= eu_datetime(article.created_at, twelve_hour: true) %>
                </div>
              </div>

              <div class="rich-content trix-content text-neutral-700 mb-4 line-clamp-3">
                <%= article.content %>
              </div>

              <div class="flex gap-4">
                <%= link_to "Read More →", article_path(article), class: "text-brand-blue-600 hover:text-brand-red-600 transition font-medium" %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-12">
      <p class="text-xl text-neutral-500 mb-4">No news articles yet.</p>
      <% if current_user&.can_create? %>
        <%= link_to "Create the first article", new_article_path, class: "btn-primary" %>
      <% end %>
    </div>
  <% end %>
</div>
